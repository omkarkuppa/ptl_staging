[Defines]
  INF_VERSION                    = 0x00010005
  BASE_NAME                      = TerminalOverDebug
  MODULE_UNI_FILE                = TerminalOverDebug.uni
  FILE_GUID                      = 7aa323d5-4200-4aa2-a6b7-f2b6d411ca2f
  MODULE_TYPE                    = UEFI_DRIVER
  VERSION_STRING                 = 1.0
  ENTRY_POINT                    = TerminalOverDebugDriverEntry

[Sources]
  TerminalOverDebugIO.c
  TerminalOverDebug.h
  TerminalOverDebug.c

[Packages]
