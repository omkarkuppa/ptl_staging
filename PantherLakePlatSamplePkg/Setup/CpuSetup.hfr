        prompt        = STRING_TOKEN (STR_MIN_PERFORMANCE_LEVEL),
        help          = STRING_TOKEN (STR_MIN_PERFORMANCE_LEVEL_HELP),
        flags         = RESET_REQUIRED,
        minimum       = 0,
        maximum       = 255,
        step          = 1,
        default       = 0,
      endnumeric;

      numeric varid   = CPU_SETUP.SkinTempOverride[SENSOR_1],
