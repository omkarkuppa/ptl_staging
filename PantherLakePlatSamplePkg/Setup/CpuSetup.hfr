        help          = STRING_TOKEN (STR_TEMP_OVERRIDE_HELP),
        flags         = RESET_REQUIRED,
        minimum       = 0,
        maximum       = 255,
        step          = 1,
        default       = 0,
      endnumeric;

  endform; //SKIN_TEMP_CONTROL_SENSOR_1_FORM_ID

  form formid = AUTO_ID(SKIN_TEMP_CONTROL_SENSOR_2_FORM_ID),
  title = STRING_TOKEN (STR_SKIN_TEMP_CONTROL_SENSOR_3_FORM_TITLE);

      SUBTITLE(STRING_TOKEN (STR_SKIN_TEMP_CONTROL_SENSOR_3_FORM_TITLE))
      SEPARATOR

      numeric varid   = CPU_SETUP.SkinTargetTemp[SENSOR_2],
        prompt        = STRING_TOKEN (STR_TARGET_TEMP),
        help          = STRING_TOKEN (STR_TARGET_TEMP_HELP),
        flags         = RESET_REQUIRED,
        minimum       = 0,
        maximum       = 255,
        step          = 1,
        default       = 0,
      endnumeric;

      oneof varid     = CPU_SETUP.SkinTempControlEnable[SENSOR_2],
        prompt        = STRING_TOKEN (STR_SKIN_CONTROL_ENABLE_MMIO),
        help          = STRING_TOKEN (STR_SKIN_CONTROL_ENABLE_MMIO_HELP),
        option text   = STRING_TOKEN (STR_DISABLED),  value = 0, flags =DEFAULT | MANUFACTURING | RESET_REQUIRED;
        option text   = STRING_TOKEN (STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      numeric varid   = CPU_SETUP.SkinControlLoopGain[SENSOR_2],
        prompt        = STRING_TOKEN (STR_CONTROL_LOOP_GAIN),
