#string STR_PVD_MODE_SELECT_SOC                                 #language en-US "PVD Mode Select for SOC "
#string STR_PVD_MODE_SELECT_SOC_HELP                            #language en-US "Select PVD Mode Value from Range 1 to 3. 0x0 = div-1 (VCO = Output clock), 0x1 = div-2 (VCO = 2x Output clock), 0x2 = div-4 (VCO = 4x Output clock), 0x3 = div-8 (VCO = 8x Output clock)"

#string STR_PVD_RATIO_THRESHOLD_CPU                             #language en-US "PVD Ratio Threshold for CPU"
#string STR_PVD_RATIO_THRESHOLD_CPU_HELP                        #language en-US "Select PVD Ratio Threshold Value from Range 1 to 63. 0 - Static PVD ratio specified by PvdMode for CPU"

#string STR_PVD_MODE_SELECT_CPU                                 #language en-US "PVD Mode Select for CPU "
#string STR_PVD_MODE_SELECT_CPU_HELP                            #language en-US "Select PVD Mode Value from Range 1 to 3. 0x0 = div-1 (VCO = Output clock), 0x1 = div-2 (VCO = 2x Output clock), 0x2 = div-4 (VCO = 4x Output clock), 0x3 = div-8 (VCO = 8x Output clock)"

#string STR_FLL_MODE_SELECT                                     #language en-US "FLL Overclock Mode Select"
#string STR_FLL_MODE_SELECT_HELP                                #language en-US "Select FLL Mode Value from Range 1 to 3. 0x0 = no overclocking, 0x1 = ratio overclocking with nominal (0.5-1x) reference clock frequency, 0x2 = BCLK overclocking with elevated (1-3x) reference clock frequency, 0x3 = BCLK overclocking with extreme elevated (3-5x) reference clock frequency and ratio limited to 63"

#string STR_CPU_D2D_RATIO                                       #language en-US "CPU D2D Ratio"
#string STR_CPU_D2D_RATIO_HELP                                  #language en-US "Set CPU D2D Ratio from Range 15 to 40. 0 indicates no setting."

#string STR_CPU_BCLK_OC_FREQUENCY                               #language en-US "CPU BCLK OC Frequency"
#string STR_CPU_BCLK_OC_FREQUENCY_HELP                          #language en-US "CPU BCLK Frequency in 10kHz increments. Specifies new CPU BCLK frequency to be applied. Frequency is rounded to nearest valid value. Allowed range is limited by the Max/Min supported frequencies. Changes are not applied until settings are saved and platform resets. Example: For 125.70MHz, enter 12570. Range is 40 MHz - 1000 MHz w/ 10KHz."

#string STR_SOC_BCLK_OC_FREQUENCY                               #language en-US "SOC BCLK OC Frequency"
#string STR_SOC_BCLK_OC_FREQUENCY_HELP                          #language en-US "SOC BCLK Frequency in 10kHz increments. Specifies new CPU BCLK frequency to be applied. Frequency is rounded to nearest valid value. Allowed range is limited by the Max/Min supported frequencies. Changes are not applied until settings are saved and platform resets. Example: For 125.70MHz, enter 12570. Range is 40 MHz - 1000 MHz w/ 10KHz."

#string STR_VCCSA_BOOT_VOLTAGE_CONFIGURATION                    #language en-US "VCCSA Boot Voltage"
#string STR_VCCSA_BOOT_VOLTAGE_CONFIGURATION_HELP               #language en-US "Select VCCSA boot voltage between Nominal and High Voltage(up to 1.2/1.3V). VCCSA boot Voltage - the default voltage is Nominal, to support the high voltage, BIOS can program the EPOC2 bits to bump up voltage to up to 1.2/1.3V.  0 - Nominal. 1 - High Voltage(up to 1.2/1.3V)."

#string STR_NOMINAL                                             #language en-US "Nominal"
#string STR_HIGH_VOLTAGE                                        #language en-US "High Voltage"

#string STR_CPU_BGREF_MODE_CONFIGURATION                        #language en-US "CPU BGREF Mode"
#string STR_CPU_BGREF_MODE_CONFIGURATION_HELP                   #language en-US "Select CPU Bandgap Reference Mode between Normal and Bandgap Bypassed. CPU Bandgap Reference Mode - the default voltage is Normal."

#string STR_NORMAL                                              #language en-US "Normal"
#string STR_BANDGAP_BYPASSED                                    #language en-US "Bandgap Bypassed"

#string STR_VCCIA_BOOT_VOLTAGE_CONFIGURATION                    #language en-US "VCCIA Boot Voltage"
#string STR_VCCIA_BOOT_VOLTAGE_CONFIGURATION_HELP               #language en-US "Select VCCIA boot voltage between Nominal and High Voltage. VCCIA boot Voltage - the default voltage is Nominal, to support the high voltage, BIOS can program VCCIA boot voltage higher than 1.65v (max 2.01v))."

#string STR_UNDERVOLT_PROTECTION                                #language en-US "UnderVolt Protection"
#string STR_UNDERVOLT_PROTECTION_HELP                           #language en-US "When UnderVolt Protection is enabled, user will not be able to program under voltage in OS runtime. Recommended to keep it enabled by default. Enabled: Allow BIOS undervolting, but enable UnderVolt Protection in Runtime. Disabled: No UnderVolt Protection in Runtime."

