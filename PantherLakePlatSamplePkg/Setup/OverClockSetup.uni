#string STR_PMC_BCLK_PCD_PLL_HELP                               #language en-US "Configure PCD BCLK PLL state. When this PLL is ON, BCLK source for SOC-N and for CPU (unless CPU PLL is ON) will be from the SOC PLL."

#string STR_PMC_BCLK_CPU_PLL_PROMPT                             #language en-US "CPU BCLK PLL configuration"
#string STR_PMC_BCLK_CPU_PLL_HELP                               #language en-US "Configure CPU BCLK PLL state. When this PLL is ON, BCLK source for CPU will be from the CPU PLL."

#string STR_PMC_BCLK_PLL_HELP                                   #language en-US "Configure BCLK PLL state. Note that values not matching default HW state will cause system to perform additional reset during next boot"
#string STR_PMC_BCLK_HW_DEFAULT                                 #language en-US "PLL in HW default state"
#string STR_PMC_BCLK_FORCE_ON                                   #language en-US "PLL ON"
#string STR_PMC_BCLK_FORCE_OFF                                  #language en-US "PLL OFF"

#string STR_FIVR_FAULTS_ENABLE                                  #language en-US "FIVR Faults"
#string STR_FIVR_FAULTS_ENABLE_HELP                             #language en-US "Enable/Disable Fivr Faults. Default is enabled. When FIVR faults are disabled, over-voltage and over-current protections are disabled. Extreme OC will require faults to be disabled, but presents reliability risks."

#string STR_FIVR_EFFICIENCY_ENABLE                              #language en-US "FIVR Efficiency"
#string STR_FIVR_EFFICIENCY_ENABLE_HELP                         #language en-US "Enable/Disable FIVR Efficiency. Default is enabled. Efficiency management is good for power delivery, but may impede OC. Disabling FIVR efficiency will force FIVR to always run in max power delivery mode."

#string STR_WDT_ENABLE                                          #language en-US "WDT Enable"
#string STR_WDT_ENABLE_HELP                                     #language en-US "Enable/Disable WatchDog Timer. Note: This option is ignored on debug BIOS."

