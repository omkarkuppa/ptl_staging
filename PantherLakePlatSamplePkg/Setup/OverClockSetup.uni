#string STR_RING_MAX_OC_RATIO                                   #language en-US "Ring Max OC Ratio"
#string STR_RING_MAX_OC_RATIO_HELP                              #language en-US "Sets the maximum OC Ratio for the CPU Ring. Uses Mailbox MSR 0x150, cmd 0x10, 0x11. Range non-turbo max - 85."

#string STR_RING_VOLTAGE_MODE                                   #language en-US "Ring Voltage Mode"
#string STR_RING_VOLTAGE_MODE_HELP                              #language en-US "Selects between Adaptive and Override Voltage modes. In Override Mode the voltage selected will be applied over all operating frequencies. In Adaptive Mode the voltage is interpolated only in turbo mode. Uses Mailbox MSR 0x150, cmd 0x10, 0x11."

#string STR_RING_VOLTAGE_OVERRIDE                               #language en-US "Ring Voltage Override"
#string STR_RING_VOLTAGE_OVERRIDE_HELP                          #language en-US "Specifies the Override Voltage applied to the Ring domain. This voltage is specified in millivolts. Range 0-2000 mV."

#string STR_RING_VOLTAGE_OFFSET                                 #language en-US "Ring Voltage Offset"
#string STR_RING_VOLTAGE_OFFSET_HELP                            #language en-US "Specifies the Offset Voltage applied to the Ring domain. This voltage is specified in millivolts. Range -500 to 500 mV"

#string STR_RING_ADAPTIVE_VOLTAGE                               #language en-US "Ring Adaptive Voltage"
#string STR_RING_ADAPTIVE_VOLTAGE_HELP                          #language en-US "Specifies the adaptive voltage applied while ring is operating in adaptive mode. Uses Mailbox MSR 0x150, cmd 0x10, 0x11. Range 0-2000 mV"

#string STR_CORE_PLL_VOLTAGE_OFFSET                             #language en-US "Core PLL Voltage Offset"
#string STR_GT_PLL_VOLTAGE_OFFSET                               #language en-US "GT PLL Voltage Offset"
#string STR_RING_PLL_VOLTAGE_OFFSET                             #language en-US "Ring PLL Voltage Offset"
#string STR_IA_ATOM_PLL_VOLTAGE_OFFSET                          #language en-US "IA Atom PLL Voltage Offset"
#string STR_PLL_VOLTAGE_OFFSET_HELP                             #language en-US "PLL Voltage Offset, Range 0-15. Units are in 17.5mV. Default is 0. This control can be used to increase the range of this domain frequency in extreme overclocking conditions."

#string STR_CORE_ADAPTIVE_VOLTAGE                               #language en-US "P-core Adaptive Voltage"
#string STR_CORE_ADAPTIVE_VOLTAGE_HELP                          #language en-US "Specifies the adaptive voltage applied while Performance-core is operating in adaptive mode. Uses Mailbox MSR 0x150, cmd 0x10, 0x11. Range 0-2000 mV"

#string STR_CORE_AVX2_RATIO_OFFSET                              #language en-US "AVX2 Ratio Offset"
#string STR_CORE_AVX2_RATIO_OFFSET_HELP                         #language en-US "AVX2 Ratio Offset. Specifies number of bins to decrease AVX ratio vs. Core Ratio. AVX is a more stressful workload, it is helpful to lower the AVX ratio to ensure maximum possible ratio for SSE workloads. Uses Mailbox MSR 0x150, cmd 0x1B. Range 0 - 31. 0 = No offset."

#string STR_CORE_AVX2_GUARD_BAND_PROMPT                         #language en-US "AVX2 Voltage Guardband Scale Factor"
#string STR_CORE_AVX2_GUARD_BAND_HELP                           #language en-US "AVX2 Voltage Guardband Scale Factor. Controls the voltage guardband applied to AVX workloads. Range 0 - 200 in 1/100 units, where 125 = 1.25 scale factor. A default value of 100 applies the default voltage guardband scale factor of 1.0. A value > 100 will increase the votlage guardband, and < 100 will decrease the voltage guardband."

#string STR_CORE_TJMAX_OFFSET                                   #language en-US "TjMax Offset"
#string STR_CORE_TJMAX_OFFSET_HELP                              #language en-US "TjMax Offset. Specified value here is clipped by pCode (125 - TjMax Offset) to support TjMax in the range of 62 to 115 deg Celsius. Uses Mailbox MSR 0x37, command 0x01. Range 10 - 63. 0 = No override."

#string STR_TVB_RATIO_CLIPPING_PROMPT                           #language en-US "TVB Ratio Clipping"
#string STR_TVB_RATIO_CLIPPING_HELP                             #language en-US "This service controls Core frequency reduction caused by high package temperatures for processors that implement the Intel Thermal Velocity Boost (TVB) feature. Uses Overclocking Mailbox command 0x18/0x19."

#string STR_TVB_VOLTAGE_OPTIMIZATION_PROMPT                     #language en-US "TVB Voltage Optimizations"
#string STR_TVB_VOLTAGE_OPTIMIZATION_HELP                       #language en-US "This service controls thermal based voltage optimizations for processors that implement the Intel Thermal Velocity Boost (TVB) feature. Default is enabled. Uses Overclocking Mailbox command 0x18/0x19."

#string STR_VR_ICCMAX_CURRENT_OVERRIDE_CONFIGURATION            #language en-US "VR ICCMAX Current Override"
#string STR_VR_ICCMAX_CURRENT_OVERRIDE_CONFIGURATION_HELP       #language en-US "VR ICCMAX Current Override Menu"

#string STR_IA_VR_ICCMAX_INFO_HELP                              #language en-US "Current IA VR Current Limit"
#string STR_IA_VR_ICCMAX_INFO_STRING                            #language en-US "Current IA VR Current Limit"
#string STR_IA_VR_ICCMAX_INFO_VALUE                             #language en-US ""

#string STR_GT_VR_ICCMAX_INFO_HELP                              #language en-US "Current GT VR Current Limit"
#string STR_GT_VR_ICCMAX_INFO_STRING                            #language en-US "Current GT VR Current Limit"
#string STR_GT_VR_ICCMAX_INFO_VALUE                             #language en-US ""

#string STR_IA_ICC_MAX_CURRENT_LIMIT_OVERRIDE                   #language en-US "IA ICC Max Current Limit Override"
#string STR_IA_ICC_MAX_CURRENT_LIMIT_OVERRIDE_HELP              #language en-US "IA Voltage Regulator Current Limit (Icc Max). This value represents the Maximum instantaneous current allowed at any given time. The value is represented in 1/4 A increments. A value of 400 = 100A. Range is 4 to 2047. Uses OC mailbox command 0x17"
#string STR_IA_ICC_UNLIMITED_MODE                               #language en-US "IA ICC Unlimited Mode"
#string STR_IA_ICC_UNLIMITED_MODE_HELP                          #language en-US "Enable/Disable IA Unlimited ICCMAX. When Enabled, IA VR ICCMAX value is set to max ICC current 512A."

#string STR_GT_ICC_MAX_CURRENT_LIMIT_OVERRIDE                   #language en-US "GT ICC Max Current Limit Override"
#string STR_GT_ICC_MAX_CURRENT_LIMIT_OVERRIDE_HELP              #language en-US "GT Voltage Regulator Current Limit (Icc Max). This value represents the Maximum instantaneous current allowed at any given time. The value is represented in 1/4 A increments. A value of 400 = 100A. Range is 4 to 2047. Uses OC mailbox command 0x17"
#string STR_GT_ICC_UNLIMITED_MODE                               #language en-US "GT ICC Unlimited Mode"
#string STR_GT_ICC_UNLIMITED_MODE_HELP                          #language en-US "Enable/Disable GT Unlimited ICCMAX. When Enabled, GT VR ICCMAX value is set to max ICC current 512A."

#string STR_BCLK_ADAPTIVE_VOLTAGE_ENABLE                        #language en-US "BCLK Aware Adaptive Voltage"
#string STR_BCLK_ADAPTIVE_VOLTAGE_ENABLE_HELP                   #language en-US "BCLK Aware Adaptive Voltage enable/disable. When enabled, pcode will be aware of the BCLK frequency when calculating the CPU V/F curves. This is ideal for BCLK OC to avoid high voltage overrides. Uses OC Mailbox command 0x15."

#string STR_VOLTAGE_ADAPTIVE                                    #language en-US "Adaptive"
#string STR_VOLTAGE_OVERRIDE                                    #language en-US "Override"

#string STR_VOLTAGE_OFFSET_LEGACY                               #language en-US "Legacy"
#string STR_VOLTAGE_OFFSET_SELECTION                            #language en-US "Selection"

