      prompt = STRING_TOKEN (STR_BUS_FREE_TIMING),
      help = STRING_TOKEN (STR_BUS_FREE_TIMING_HELP),
      flags = RESET_REQUIRED | DISPLAY_UINT_HEX,  minimum = 0, maximum = 0xFFFFFFFF, default = 0x8,
