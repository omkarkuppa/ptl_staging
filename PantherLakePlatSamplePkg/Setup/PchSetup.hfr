    //
    oneof varid  = PCH_SETUP.PchUsbPortDisable,
      prompt   = STRING_TOKEN(STR_PCH_USB_PORT_TERM_PROMPT),
      help     = STRING_TOKEN(STR_PCH_USB_PORT_TERM_HELP),
