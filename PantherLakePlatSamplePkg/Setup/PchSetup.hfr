      option text = STRING_TOKEN(STR_PCH_USB3_1_GEN_2_SPEED), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      option text = STRING_TOKEN(STR_PCH_USB3_1_GEN_1_SPEED), value = 1, flags = RESET_REQUIRED;
    endoneof;
#endif

    //
