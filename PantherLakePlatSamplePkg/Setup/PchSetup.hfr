      #include "PchUsbSingleHsPort.hfr"
      #undef PCH_HS_PORT_INDEX

    endif; // if PchUsbPortDisable == 0x0

#if FixedPcdGet8(PcdEmbeddedEnable) == 0x1
      SEPARATOR
      //
