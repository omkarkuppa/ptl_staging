        option text = STRING_TOKEN(STR_FALSE), value = 0, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = SETUP_DATA.UsbcCapsuleDebugLevel,
        prompt      = STRING_TOKEN(STR_USBC_CAPSULE_DEBUG_LEVEL_PROMPT),
        help        = STRING_TOKEN(STR_USBC_CAPSULE_DEBUG_LEVEL_HELP),
        option text = STRING_TOKEN(STR_USBC_CAPSULE_DEBUG_LEVEL_DISABLED), value = 0, flags = DEFAULT | RESET_REQUIRED | INTERACTIVE;
        option text = STRING_TOKEN(STR_USBC_CAPSULE_DEBUG_LEVEL_ERROR), value = 1, flags = RESET_REQUIRED | INTERACTIVE;
        option text = STRING_TOKEN(STR_USBC_CAPSULE_DEBUG_LEVEL_WARN), value = 2, flags = RESET_REQUIRED | INTERACTIVE;
        option text = STRING_TOKEN(STR_USBC_CAPSULE_DEBUG_LEVEL_INFO), value = 3, flags = RESET_REQUIRED | INTERACTIVE;
        option text = STRING_TOKEN(STR_USBC_CAPSULE_DEBUG_LEVEL_VERBOSE), value = 4, flags = RESET_REQUIRED | INTERACTIVE;
      endoneof;

      goto TBT_FORM_ID,
        prompt = STRING_TOKEN(STR_TBT_FORM),
        help   = STRING_TOKEN(STR_TBT_FORM_HELP);

#if FixedPcdGet8 (PcdMaxUsbCPdNumber) >= 1
      SEPARATOR
      SUBTITLE(STRING_TOKEN(STR_PD_INFORMATION))

      //
      // PD for TCP0
      //
      text
        help  = STRING_TOKEN(STR_TCP0_PD_VERSION_HELP),
        text  = STRING_TOKEN(STR_TCP0_PD_VERSION_NAME),
        text  = STRING_TOKEN(STR_TCP0_PD_VERSION_VALUE),
        flags = 0,
        key   = 0;
