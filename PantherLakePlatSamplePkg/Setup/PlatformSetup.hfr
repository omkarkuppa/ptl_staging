        oneof varid   = SETUP_DATA.DeepestUSBSleepWakeCapability,
          questionid  = AUTO_ID(KEY_DEEPEST_USB_SLEEP_WAKE_CAPABILITY),
          prompt      = STRING_TOKEN(STR_DEEPEST_USB_SLEEP_WAKE_CAPABILITY),
