      endoneof;

      suppressif (ideqval SETUP_DATA.UsbcBiosTcssHandshake == 0);
        numeric varid  = SETUP_DATA.UsbConnStatusTimeout,
          prompt     = STRING_TOKEN(STR_TCSS_USB_CONN_STATUS_TIMEOUT),
