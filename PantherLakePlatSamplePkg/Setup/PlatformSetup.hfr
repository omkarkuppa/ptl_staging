          minimum       = 0,
          maximum       = 7,
          step          = 1,
          default       = 0,
        endnumeric;

        numeric varid   = SETUP_DATA.StcMinPerfLevel[2],
          prompt        = STRING_TOKEN (STRING_STC_SENSOR3_MIN_PERFORMANCE_LEVEL_SETTINGS),
          help          = STRING_TOKEN (STRING_STC_SENSOR3_MIN_PERFORMANCE_LEVEL_SETTINGS_HELP),
          flags         = RESET_REQUIRED,
          minimum       = 0,
          maximum       = 255,
          step          = 1,
          default       = 0,
        endnumeric;
      endif;

    endform;
