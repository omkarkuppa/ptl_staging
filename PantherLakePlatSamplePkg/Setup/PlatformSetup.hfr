        text  = STRING_TOKEN(STR_TCP3_PD_VERSION_VALUE),
        flags = 0,
        key   = 0;
#endif

      suppressif NOT ideqval SETUP_DATA.UsbCRetimerNumber > 0;
        SEPARATOR
        SUBTITLE(STRING_TOKEN(STR_RETIMER_INFORMATION))
      endif;

      suppressif NOT ideqval SETUP_DATA.UsbCRetimerNumber > 0;
        text
          help  = STRING_TOKEN(STR_RETIMER0_VERSION_HELP),
          text  = STRING_TOKEN(STR_RETIMER0_VERSION_NAME),
          text  = STRING_TOKEN(STR_RETIMER0_VERSION_VALUE),
