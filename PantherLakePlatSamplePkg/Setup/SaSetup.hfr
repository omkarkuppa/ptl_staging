         option text = STRING_TOKEN (STR_CUSTOM_PROFILE),      value = 1, flags = RESET_REQUIRED;
         suppressif ideqval SA_SETUP.XmpProfileEnable == 0x0;
           option text = STRING_TOKEN (STR_XMP_PROFILE_1),     value = 2, flags = RESET_REQUIRED;
