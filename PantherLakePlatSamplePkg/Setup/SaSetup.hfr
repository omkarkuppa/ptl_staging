        prompt      = STRING_TOKEN(STR_MIPICAM_DEVICES_CUSTOMIZE1_ID),
        help        = STRING_TOKEN(STR_MIPICAM_DEVICES_CUSTOMIZE_ID_HELP),
        minimum     = 17,
        maximum     = 255,
        step        = 1,
      endnumeric;

      numeric varid = MIPICAM_CONFIG.MipiCam_Link3_Customize_Id[1],
