              flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
              minimum     = 0,
              maximum     = 0x1F,
              step        = 1,
            endnumeric;

            // WLED1 Torch Max current
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic5_Wled1TorchMaxCurrent,
              prompt      = STRING_TOKEN(STR_MIPICAM_WLED1_TORCH_MAX_CURRENT),
