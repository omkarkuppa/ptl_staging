          option text = STRING_TOKEN(STR_MIPICAM_I2C_DEVICE_TYPE_IO_EXPANDER), value = 0x0A, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_I2C_DEVICE_TYPE_FLASH),       value = 0x0C, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_I2C_DEVICE_TYPE_CUST_DEV01),  value = 0x0D, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_I2C_DEVICE_TYPE_CUST_DEV02),  value = 0x0E, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_I2C_DEVICE_TYPE_CUST_DEV03),  value = 0x0F, flags = RESET_REQUIRED;
        endoneof;
