      SEPARATOR

      oneof varid  = SA_SETUP.WrDqDqsReTraining,
        prompt      = STRING_TOKEN (STR_DQ_DQS_RE_TRAINING_PROMPT),
        help        = STRING_TOKEN (STR_DQ_DQS_RE_TRAINING_HELP),
        option text = STRING_TOKEN (STR_DISABLED_STRING), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN (STR_ENABLED_STRING),  value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      endoneof;

      numeric varid  = SA_SETUP.SafeModeOverride,
        prompt  = STRING_TOKEN (STR_MRC_SAFEMODEOVERRIDE_PROMPT),
        help    = STRING_TOKEN (STR_MRC_SAFEMODEOVERRIDE_HELP),
        flags   = RESET_REQUIRED,
        minimum = 0,
        maximum = 0xFF,
        step    = 1,
        default = 0xFF,
      endnumeric;

      grayoutif cond ((get(SA_SETUP.SafeModeOverride) & 0x2) == 0 ? 0 : 1);
        numeric varid  = SA_SETUP.McSafeMode,
          prompt  = STRING_TOKEN (STR_MC_SAFEMODE_PROMPT),
          help    = STRING_TOKEN (STR_MC_SAFEMODE_HELP),
          flags   = RESET_REQUIRED,
          minimum = 0,
          maximum = 0xFF,
          step    = 1,
          default = 2,
        endnumeric;
      endif;

      grayoutif cond ((get(SA_SETUP.SafeModeOverride) & 0x1) == 0 ? 0 : 1);
        numeric varid  = SA_SETUP.DdrSafeMode,
          prompt  = STRING_TOKEN (STR_DDR_SAFEMODE_PROMPT),
          help    = STRING_TOKEN (STR_DDR_SAFEMODE_HELP),
          flags   = RESET_REQUIRED,
          minimum = 0,
          maximum = 0xFFFF,
          step    = 1,
          default = 0,
        endnumeric;
      endif;

      oneof varid  = SA_SETUP.MemTestOnWarmBoot,
        prompt   = STRING_TOKEN (STR_MEMTEST_WARMBOOT_SUPPORT_PROMPT),
        help     = STRING_TOKEN (STR_MEMTEST_WARMBOOT_SUPPORT_HELP),
        option text = STRING_TOKEN (STR_DISABLED_STRING), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN (STR_ENABLED_STRING), value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      endoneof;

      numeric varid  = SA_SETUP.LpMode,
        prompt  = STRING_TOKEN (STR_LPMODE_PROMPT),
        help    = STRING_TOKEN (STR_LPMODE_HELP),
        flags   = RESET_REQUIRED,
        minimum = 0,
        maximum = 0x80,
        step    = 1,
        default = 0,
      endnumeric;

      oneof varid  = SA_SETUP.LpMode4,
        prompt   = STRING_TOKEN (STR_LPMODE4_PROMPT),
