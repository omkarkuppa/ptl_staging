          // WLED2 Type
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic5_Wled2Type,
            prompt      = STRING_TOKEN(STR_MIPICAM_WLED2_TYPE),
            help        = STRING_TOKEN(STR_MIPICAM_WLED_TYPE),
