          option text = STRING_TOKEN(STR_MIPICAM_PMIC_POSITION_2), value = 1, flags = RESET_REQUIRED;
        endoneof;
      endif;

      // Voltage Rail
      suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_Link0_DriverData_PmicPosition == 1;
        oneof varid   = MIPICAM_CONFIG.MipiCam_Link0_DriverData_VoltageRail,
