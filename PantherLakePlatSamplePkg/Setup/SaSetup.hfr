        // I2C address
        numeric varid = MIPICAM_CONFIG.MipiCam_Link5_I2cAddress[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_LINK_I2C_ADDRESS),
          help        = STRING_TOKEN(STR_MIPICAM_I2C_ADDRESS_MAIN),
          flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
