          text   = STRING_TOKEN(STR_DIMM_MC0_CH3_SLT0_STATUS),
          flags  = 0,
          key    = 0;

        suppressif ideqval SETUP_VOLATILE_DATA.DimmPresent[OFFSET_6] == 0x0;
