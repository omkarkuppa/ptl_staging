        option text = STRING_TOKEN(STR_CHANNEL_I2C2), value = 2, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C3), value = 3, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C4), value = 4, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C5), value = 5, flags = RESET_REQUIRED;
      endoneof;

      // I2C address
      numeric varid = MIPICAM_CONFIG.MipiCam_Flash4_I2cAddress,
        prompt      = STRING_TOKEN(STR_MIPICAM_I2C_ADDRESS_MAIN),
        help        = STRING_TOKEN(STR_MIPICAM_I2C_ADDRESS_MAIN),
        flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum     = 0,
        maximum     = 0x7F,
        step        = 1,
      endnumeric;

      // Flash4 Gpio Support
      oneof varid   = MIPICAM_CONFIG.MipiCam_Flash4_GpioSupport,
        prompt      = STRING_TOKEN(STR_MIPICAM_FLASH_TRIGGER_GPIO_SUPPORT),
        help        = STRING_TOKEN(STR_MIPICAM_FLASH_TRIGGER_GPIO_SUPPORT),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      suppressif ideqval MIPICAM_CONFIG.MipiCam_Flash4_GpioSupport == 0;
        // GPIO Group Pad Number
        numeric varid = MIPICAM_CONFIG.MipiCam_Flash4_GpioGroupPadNumber,
          prompt      = STRING_TOKEN(STR_MIPICAM_FLASH_GPIO_GROUP_PAD_NUMBER),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 88,
          step        = 1,
        endnumeric;

        // GPIO Group Number
          oneof varid   = MIPICAM_CONFIG.MipiCam_Flash4_GpioGroupNumber,
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_B_F_S_V), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_C_D_E_H), value = 0x01, flags = RESET_REQUIRED;
          endoneof;

          oneof varid   = MIPICAM_CONFIG.MipiCam_Flash4_GpioComNumber,
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER0), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER1), value = 0x01, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER3), value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER4), value = 0x03, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER5), value = 0x04, flags = RESET_REQUIRED;
          endoneof;

        // GPIO Active Value
        numeric varid = MIPICAM_CONFIG.MipiCam_Flash4_GpioActiveValue,
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 1,
          step        = 1,
        endnumeric;

        // GPIO Initial Value
        numeric varid = MIPICAM_CONFIG.MipiCam_Flash4_GpioInitialValue,
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 1,
          step        = 1,
        endnumeric;
      endif;
    endform;

    // *********************************************************
    form formid     = AUTO_ID(IMAGING_FLASH5_FORM_ID),
      title         = STRING_TOKEN(STR_MIPICAM_FLASH_OPTIONS);
      subtitle text = STRING_TOKEN(STR_MIPICAM_CAMERA6_FLASH_CONF);

      oneof varid   = MIPICAM_CONFIG.MipiCam_Flash5_Model,
        prompt      = STRING_TOKEN(STR_MIPICAM_FLASH_MODEL),
        help        = STRING_TOKEN(STR_MIPICAM_FLASH_MODEL),
        option text = STRING_TOKEN(STR_MIPICAM_LM3643), value = 0,    flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_USER),   value = 0xFF, flags = RESET_REQUIRED;
      endoneof;

      suppressif NOT ideqvallist MIPICAM_CONFIG.MipiCam_Flash5_Model == 0xFF;
        // Flash Model Custom HID
        string varid = MIPICAM_CONFIG.MipiCam_Flash5_UserHid,
          prompt     = STRING_TOKEN(STR_MIPICAM_CUSTOM_HID),
          help       = STRING_TOKEN(STR_MIPICAM_CUSTOM_HID),
          minsize    = MIPICAM_HID_MIN_LENGTH,
          maxsize    = MIPICAM_HID_MAX_LENGTH,
        endstring;
      endif;

      oneof varid   = MIPICAM_CONFIG.MipiCam_Flash5_Mode,
        prompt      = STRING_TOKEN(STR_MIPICAM_FLASH_MODE),
        help        = STRING_TOKEN(STR_MIPICAM_FLASH_MODE_HELP),
        option text = STRING_TOKEN(STR_DISABLED),  value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_WHITE_LED), value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_IR_LED),    value = 3, flags = RESET_REQUIRED;
      endoneof;

      // Flash Module Name
      string varid = MIPICAM_CONFIG.MipiCam_Flash5_ModuleName,
        prompt     = STRING_TOKEN(STR_MIPICAM_MODULE_NAME),
        help       = STRING_TOKEN(STR_MIPICAM_MODULE_NAME),
        minsize    = 1,
        maxsize    = 15,
      endstring;

      // I2C Channel
      oneof varid   = MIPICAM_CONFIG.MipiCam_Flash5_I2cChannel,
        prompt      = STRING_TOKEN(STR_MIPICAM_I2C_CHANNEL),
        help        = STRING_TOKEN(STR_MIPICAM_I2C_CHANNEL),
        option text = STRING_TOKEN(STR_CHANNEL_I2C0), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C1), value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C2), value = 2, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C3), value = 3, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C4), value = 4, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_CHANNEL_I2C5), value = 5, flags = RESET_REQUIRED;
      endoneof;

      // I2C address
      numeric varid = MIPICAM_CONFIG.MipiCam_Flash5_I2cAddress,
        prompt      = STRING_TOKEN(STR_MIPICAM_I2C_ADDRESS_MAIN),
        help        = STRING_TOKEN(STR_MIPICAM_I2C_ADDRESS_MAIN),
        flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum     = 0,
        maximum     = 0x7F,
        step        = 1,
      endnumeric;

      // Flash5 Gpio Support
      oneof varid   = MIPICAM_CONFIG.MipiCam_Flash5_GpioSupport,
        prompt      = STRING_TOKEN(STR_MIPICAM_FLASH_TRIGGER_GPIO_SUPPORT),
        help        = STRING_TOKEN(STR_MIPICAM_FLASH_TRIGGER_GPIO_SUPPORT),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED ;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      suppressif ideqval MIPICAM_CONFIG.MipiCam_Flash5_GpioSupport == 0;
        // GPIO Group Pad Number
        numeric varid = MIPICAM_CONFIG.MipiCam_Flash5_GpioGroupPadNumber,
          prompt      = STRING_TOKEN(STR_MIPICAM_FLASH_GPIO_GROUP_PAD_NUMBER),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 88,
          step        = 1,
        endnumeric;

        // GPIO Group Number
          oneof varid   = MIPICAM_CONFIG.MipiCam_Flash5_GpioGroupNumber,
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_B_F_S_V), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_C_D_E_H), value = 0x01, flags = RESET_REQUIRED;
          endoneof;

          oneof varid   = MIPICAM_CONFIG.MipiCam_Flash5_GpioComNumber,
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER0), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER1), value = 0x01, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER3), value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER4), value = 0x03, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER5), value = 0x04, flags = RESET_REQUIRED;
          endoneof;

        // GPIO Active Value
        numeric varid = MIPICAM_CONFIG.MipiCam_Flash5_GpioActiveValue,
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 1,
          step        = 1,
        endnumeric;

        // GPIO Initial Value
        numeric varid = MIPICAM_CONFIG.MipiCam_Flash5_GpioInitialValue,
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 1,
          step        = 1,
        endnumeric;
      endif;
    endform;
#endif

    // TCSS
    form formid = AUTO_ID(SA_TCSS_OPTIONS_FORM_ID),
    title     = STRING_TOKEN(STR_SA_TCSS_OPTIONS_FORM_TITLE);

    SUBTITLE(STRING_TOKEN(STR_SA_TCSS_OPTIONS_FORM_SUBTITLE))
    SEPARATOR
    SUBTITLE(STRING_TOKEN(STR_TCSS_IOM_VERSION_STRING))
    SEPARATOR
    SUBTITLE(STRING_TOKEN(STR_TCSS_PHY_VERSION_STRING))
    SEPARATOR
    SUBTITLE(STRING_TOKEN(STR_TCSS_TBT_STATUS_STRING))
    SUBTITLE(STRING_TOKEN(STR_TCSS_TBT_VERSION_STRING))
    SUBTITLE(STRING_TOKEN(STR_TC_CSTATE_STATUS))
    SEPARATOR
    oneof varid   = SA_SETUP.TcssXhciEn,
      questionid  = AUTO_ID(KEY_SA_TCSS_XHCI_EN),
      prompt      = STRING_TOKEN(STR_TCSS_XHCI_PROMPT),
      help        = STRING_TOKEN(STR_TCSS_XHCI_HELP),
      option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED | INTERACTIVE;
      option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED | INTERACTIVE;
    endoneof;

    suppressif ideqval SA_SETUP.TcssXhciEn == 0;
      grayoutif ideqval TBT_SETUP_VOLATILE_DATA.TcssPortEnable[TCSS_PORT0] == 0;
        oneof varid   = SA_SETUP.TcssPortConf[0],
          prompt      = STRING_TOKEN(STR_TCSS_PORT0_PROMPT),
          help        = STRING_TOKEN(STR_TCSS_PORT_HELP),
          option text = STRING_TOKEN(STR_DISABLED),                 value = DISABLE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_DP_ONLY),        value = DP_ONLY,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_THUNDERBOLT), value = NO_TBT,    flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_PCIE),        value = NO_PCIE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_FULL_FUNCTION),  value = FULL_FUNC, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED | INTERACTIVE;
        endoneof;
      endif;

      grayoutif ideqval TBT_SETUP_VOLATILE_DATA.TcssPortEnable[TCSS_PORT1] == 0;
        oneof varid   = SA_SETUP.TcssPortConf[1],
          prompt      = STRING_TOKEN(STR_TCSS_PORT1_PROMPT),
          help        = STRING_TOKEN(STR_TCSS_PORT_HELP),
          option text = STRING_TOKEN(STR_DISABLED),                 value = DISABLE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_DP_ONLY),        value = DP_ONLY,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_THUNDERBOLT), value = NO_TBT,    flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_PCIE),        value = NO_PCIE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_FULL_FUNCTION),  value = FULL_FUNC, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED | INTERACTIVE;
        endoneof;
      endif;

      grayoutif ideqval TBT_SETUP_VOLATILE_DATA.TcssPortEnable[TCSS_PORT2] == 0;
        oneof varid   = SA_SETUP.TcssPortConf[2],
          prompt      = STRING_TOKEN(STR_TCSS_PORT2_PROMPT),
          help        = STRING_TOKEN(STR_TCSS_PORT_HELP),
          option text = STRING_TOKEN(STR_DISABLED),                 value = DISABLE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_DP_ONLY),        value = DP_ONLY,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_THUNDERBOLT), value = NO_TBT,    flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_PCIE),        value = NO_PCIE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_FULL_FUNCTION),  value = FULL_FUNC, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED | INTERACTIVE;
        endoneof;
      endif;

      grayoutif ideqval TBT_SETUP_VOLATILE_DATA.TcssPortEnable[TCSS_PORT3] == 0;
        oneof varid   = SA_SETUP.TcssPortConf[3],
          prompt      = STRING_TOKEN(STR_TCSS_PORT3_PROMPT),
          help        = STRING_TOKEN(STR_TCSS_PORT_HELP),
          option text = STRING_TOKEN(STR_DISABLED),                 value = DISABLE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_DP_ONLY),        value = DP_ONLY,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_THUNDERBOLT), value = NO_TBT,    flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_NO_PCIE),        value = NO_PCIE,   flags = RESET_REQUIRED | INTERACTIVE;
          option text = STRING_TOKEN(STR_TCSS_PORT_FULL_FUNCTION),  value = FULL_FUNC, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED | INTERACTIVE;
        endoneof;
      endif;

      // VCCST Status
      oneof varid   = SA_SETUP.TcssVccstStatus,
        prompt      = STRING_TOKEN(STR_TCSS_VCCST_STATUS),
        help        = STRING_TOKEN(STR_TCSS_VCCST_STATUS_HELP),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      endoneof;

      // TCSS D3 cold Enable\Disable
      oneof varid   = SA_SETUP.TcssD3ColdEnable,
        prompt      = STRING_TOKEN(STR_TCSS_D3_COLD),
        help        = STRING_TOKEN(STR_TCSS_D3_COLD_HELP),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      endoneof;

      // TypeC Cstate option
      oneof varid   = SA_SETUP.TcStateLimit,
        prompt      = STRING_TOKEN(STR_TC_CSTATE_LIMIT),
        help        = STRING_TOKEN(STR_TC_CSTATE_LIMIT_HELP),
        default  = 10, defaultstore = MyStandardDefault,
        option text = STRING_TOKEN(STR_TC_STATE_0),  value = 0,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TC_STATE_1),  value = 1,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TC_STATE_2),  value = 2,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TC_STATE_4),  value = 4,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TC_STATE_5),  value = 5,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TC_STATE_6),  value = 6,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TC_STATE_7),  value = 7,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TC_STATE_10), value = 10, flags = RESET_REQUIRED;
      endoneof;

      // TypeC Notify Igd option
      oneof varid   = SA_SETUP.TcNotifyIgd,
        prompt      = STRING_TOKEN(STR_TC_NOTIFY_IGD),
        help        = STRING_TOKEN(STR_TC_NOTIFY_IGD_HELP),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = RESET_REQUIRED;
      endoneof;

      grayoutif (NOT ideqval SA_SETUP.TcssPortConf[TCSS_PORT0] == FULL_FUNC) OR
                 ideqval TBT_SETUP_VOLATILE_DATA.BoardITbtPcieRootPortSupported[TCSS_PORT0] == 0;
      goto ITBT_PCIERP0_OPTIONS_FORM_ID,
        prompt = STRING_TOKEN(STR_ITBT_PCIERP0_OPTIONS_FORM_TITLE),
        help = STRING_TOKEN(STR_ITBT_PCIERP_OPTIONS_FORM_HELP);
      endif;

      grayoutif (NOT ideqval SA_SETUP.TcssPortConf[TCSS_PORT1] == FULL_FUNC) OR
                 ideqval TBT_SETUP_VOLATILE_DATA.BoardITbtPcieRootPortSupported[TCSS_PORT1] == 0;
      goto ITBT_PCIERP1_OPTIONS_FORM_ID,
        prompt = STRING_TOKEN(STR_ITBT_PCIERP1_OPTIONS_FORM_TITLE),
        help = STRING_TOKEN(STR_ITBT_PCIERP_OPTIONS_FORM_HELP);
      endif;

      grayoutif (NOT ideqval SA_SETUP.TcssPortConf[TCSS_PORT2] == FULL_FUNC) OR
                 ideqval TBT_SETUP_VOLATILE_DATA.BoardITbtPcieRootPortSupported[TCSS_PORT2] == 0;
      goto ITBT_PCIERP2_OPTIONS_FORM_ID,
        prompt = STRING_TOKEN(STR_ITBT_PCIERP2_OPTIONS_FORM_TITLE),
        help = STRING_TOKEN(STR_ITBT_PCIERP_OPTIONS_FORM_HELP);
      endif;

      grayoutif (NOT ideqval SA_SETUP.TcssPortConf[TCSS_PORT3] == FULL_FUNC) OR
                 ideqval TBT_SETUP_VOLATILE_DATA.BoardITbtPcieRootPortSupported[TCSS_PORT3] == 0;
      goto ITBT_PCIERP3_OPTIONS_FORM_ID,
        prompt = STRING_TOKEN(STR_ITBT_PCIERP3_OPTIONS_FORM_TITLE),
        help = STRING_TOKEN(STR_ITBT_PCIERP_OPTIONS_FORM_HELP);
      endif;

    endif;
  endform;

  // VMD setup
    form formid = AUTO_ID(SA_VMD_OPTIONS_FORM_ID),
    title     = STRING_TOKEN(STR_SA_VMD_OPTIONS_FORM_TITLE);

    SUBTITLE(STRING_TOKEN(STR_SA_VMD_OPTIONS_FORM_SUBTITLE))
    SEPARATOR

    oneof varid   = SA_SETUP.VmdEnable,
      prompt      = STRING_TOKEN(STR_SA_VMD_SUPPORT_PROMPT),
      help        = STRING_TOKEN(STR_SA_VMD_SUPPORT_HELP),
      option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      option text = STRING_TOKEN(STR_ENABLED), value = 1, flags =  RESET_REQUIRED;
    endoneof;

    SEPARATOR

    // Suppress rest of the VMD configurations if VMD is not enabled.
    suppressif ideqval SA_SETUP.VmdEnable == 0x0;

      oneof varid   = SA_SETUP.VmdGlobalMapping,
        questionid  = KEY_SA_VMD_GLOBAL_MAPPING,
        prompt      = STRING_TOKEN(STR_SA_VMD_GLOBAL_MAPPING_PROMPT),
        help        = STRING_TOKEN(STR_SA_VMD_GLOBAL_MAPPING_HELP),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED | INTERACTIVE;
        option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = RESET_REQUIRED | INTERACTIVE;
      endoneof;
      SEPARATOR

      grayoutif ideqval SA_SETUP.VmdGlobalMapping == 0x1;
        suppressif ideqval SA_SETUP.VmdPortPresent[0] == 0x0;
          oneof varid     = SA_SETUP.VmdPort[0],
            prompt        = STRING_TOKEN(STR_RP1_BDF_VALUE),
            help          = STRING_TOKEN(STR_SA_VMDPORT_SUPPORT_HELP),
            default value = cond((get(SA_SETUP.VmdGlobalMapping) & 0x1) == 1 ? 0x0 : 0x1), defaultstore = MyStandardDefault,
            option text   = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text   = STRING_TOKEN(STR_ENABLED), value = 1, flags =  RESET_REQUIRED;
          endoneof;
          SEPARATOR
        endif;

        suppressif ideqval SA_SETUP.VmdPortPresent[1] == 0x0;
          oneof varid     = SA_SETUP.VmdPort[1],
            prompt        = STRING_TOKEN(STR_RP2_BDF_VALUE),
            help          = STRING_TOKEN(STR_SA_VMDPORT_SUPPORT_HELP),
            default value = cond((get(SA_SETUP.VmdGlobalMapping) & 0x1) == 1 ? 0x0 : 0x1), defaultstore = MyStandardDefault,
            option text   = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text   = STRING_TOKEN(STR_ENABLED), value = 1, flags =  RESET_REQUIRED;
          endoneof;
          SEPARATOR
        endif;

        suppressif ideqval SA_SETUP.VmdPortPresent[2] == 0x0;
          oneof varid     = SA_SETUP.VmdPort[2],
            prompt        = STRING_TOKEN(STR_RP3_BDF_VALUE),
            help          = STRING_TOKEN(STR_SA_VMDPORT_SUPPORT_HELP),
            default value = cond((get(SA_SETUP.VmdGlobalMapping) & 0x1) == 1 ? 0x0 : 0x1), defaultstore = MyStandardDefault,
            option text   = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text   = STRING_TOKEN(STR_ENABLED), value = 1, flags =  RESET_REQUIRED;
          endoneof;
          SEPARATOR
        endif;

        suppressif ideqval SA_SETUP.VmdPortPresent[3] == 0x0;
