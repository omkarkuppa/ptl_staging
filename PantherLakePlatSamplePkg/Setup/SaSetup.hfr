        option text = STRING_TOKEN(STR_MIPICAM_PHY_CONFIG_1), value = 1, flags = RESET_REQUIRED;
      endoneof;

      // Lane Configuration
      numeric varid = MIPICAM_CONFIG.MipiCam_Link0_DriverData_LaneConfiguration,
        prompt      = STRING_TOKEN(STR_MIPICAM_LANE_CONFIG),
