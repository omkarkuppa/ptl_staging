        option text = STRING_TOKEN(STR_NEG_4) , value = 0xFC, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_POS_5) , value = 5,    flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_NEG_5) , value = 0xFB, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_POS_6) , value = 6,    flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_NEG_6) , value = 0xFA, flags = RESET_REQUIRED;
      endoneof;

      numeric varid = SA_SETUP.CntrlrMask,
        prompt      = STRING_TOKEN(STR_CNTRL_MASK_PROMPT),
        help        = STRING_TOKEN(STR_CNTRL_MASK_HELP),
        flags       = RESET_REQUIRED,
        minimum     = 0,
