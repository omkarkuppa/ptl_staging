            option text = STRING_TOKEN (STR_ENABLED_STRING),  value = 1, flags = RESET_REQUIRED;
          endoneof;

          suppressif ideqval SA_SETUP.IbeccProtectedRegionEnable[OFFSET_0] == 0x0;
            // IbeccProtectedRegionOverallBase is used for user input only that is based on how many IBECC instance is enabled (Memory Physical Address).
            // The actual variable that passed in to MRC is IbeccProtectedRegionBase, which is per IBECC instance.
            // The default for IbeccProtectedRegionOverallBase and IbeccProtectedRegionBase has to be aligned.
            numeric varid  = SA_SETUP.IbeccProtectedRegionOverallBase[OFFSET_0],
              prompt   = STRING_TOKEN (STR_IBECC_PROTECTED_0_BASE_PROMPT),
              help     = STRING_TOKEN (STR_IBECC_PROTECTED_0_BASE_PROMPT_HELP),
              flags    = RESET_REQUIRED | INTERACTIVE,
              key      = AUTO_ID(KEY_IBECC_BASE0_CHECK),
              minimum  = 0x0000,
              maximum  = 0x7FFE,
              step     = 0,
              default  = 0,
            endnumeric;

            oneof varid  = SA_SETUP.IbeccProtectedRegionMask[OFFSET_0],
              questionid = AUTO_ID(KEY_IBECC_MASK0_CHECK),
              prompt   = STRING_TOKEN (STR_IBECC_PROTECTED_0_MASK_PROMPT),
              help     = STRING_TOKEN (STR_IBECC_PROTECTED_0_MASK_PROMPT_HELP),
              option text = STRING_TOKEN (STR_32MB_IBECC_STRING), value = 0x3FFF, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED | INTERACTIVE;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 2;
                option text = STRING_TOKEN (STR_64MB_IBECC_STRING), value = 0x3FFE, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 4;
                option text = STRING_TOKEN (STR_128MB_IBECC_STRING), value = 0x3FFC, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 8;
                option text = STRING_TOKEN (STR_256MB_IBECC_STRING), value = 0x3FF8, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 16;
                option text = STRING_TOKEN (STR_512MB_IBECC_STRING), value = 0x3FF0, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 32;
                option text = STRING_TOKEN (STR_1GB_IBECC_STRING), value = 0x3FE0, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 64;
                option text = STRING_TOKEN (STR_2GB_IBECC_STRING), value = 0x3FC0, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 128;
                option text = STRING_TOKEN (STR_4GB_IBECC_STRING), value = 0x3F80, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 256;
                option text = STRING_TOKEN (STR_8GB_IBECC_STRING), value = 0x3F00, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 512;
                option text = STRING_TOKEN (STR_16GB_IBECC_STRING), value = 0x3E00, flags = RESET_REQUIRED | INTERACTIVE;
              endif;
              suppressif ideqval SETUP_VOLATILE_DATA.MemorySizeIn32MB < 1024;
                option text = STRING_TOKEN (STR_32GB_IBECC_STRING), value = 0x3C00, flags = RESET_REQUIRED | INTERACTIVE;
