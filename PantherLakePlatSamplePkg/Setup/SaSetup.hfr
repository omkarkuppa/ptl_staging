        option text = STRING_TOKEN(STR_MIPICAM_LANES_X3), value = 3, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_LANES_X4), value = 4, flags = RESET_REQUIRED;
