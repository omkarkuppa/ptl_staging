        option text = STRING_TOKEN (STR_DISABLED_STRING),                   value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
        option text = STRING_TOKEN (STR_ENABLED_STRING),                    value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN (STR_LPMODE4_DYNAMIC_THRESHOD_2_STRING), value = 2, flags = RESET_REQUIRED;
        option text = STRING_TOKEN (STR_LPMODE4_DYNAMIC_THRESHOD_3_STRING), value = 3, flags = RESET_REQUIRED;
      endoneof;

      oneof varid  = SA_SETUP.Ddr5AutoPrechargeEnable,
