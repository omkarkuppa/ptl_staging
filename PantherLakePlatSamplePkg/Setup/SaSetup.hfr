          suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioFunction[4] == 0xFF;
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioFunction_User[4],
              prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),
              help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM_HELP),
              flags       = DISPLAY_UINT_HEX,
              minimum     = 0x15,
              maximum     = 0xFF,
              step        = 1,
            endnumeric;
          endif;

          // GPIO Active Value
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioActiveValue[4],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 1,
            step        = 1,
          endnumeric;

          // GPIO Initial Value
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioInitialValue[4],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 1,
            step        = 1,
          endnumeric;
        endif;

        suppressif ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioPinsEnabled == 0 1 2 3 4 5;
          // GPIO Pin 5
          subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_GPIO_5);
          // GPIO Group Pad Number
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioGroupPadNumber[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 23,
            step        = 1,
          endnumeric;

          // GPIO Group Number
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioGroupNumber[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_B_F_S_V), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_C_D_E_H), value = 0x01, flags = RESET_REQUIRED;
          endoneof;

          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioComNumber[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER0), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER1), value = 0x01, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER3), value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER4), value = 0x03, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER5), value = 0x04, flags = RESET_REQUIRED;
          endoneof;

          // GPIO Function
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioFunction[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_RESET),        value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_POWER_EN),     value = 0x0B, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CLOCK_EN),     value = 0x0C, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_PLED_EN),      value = 0x0D, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_STROBE_EN),    value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_HANDSHAKE_EN), value = 0x12, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),       value = 0xFF, flags = RESET_REQUIRED;
          endoneof;

          // User defined GPIO Function for Control Logic 4
          suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioFunction[5] == 0xFF;
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic4_GpioFunction_User[5],
