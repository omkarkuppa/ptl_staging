          suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic0_GpioFunction[5] == 0xFF;
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic0_GpioFunction_User[5],
