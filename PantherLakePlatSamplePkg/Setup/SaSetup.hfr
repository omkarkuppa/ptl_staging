        option text = STRING_TOKEN(STR_MIPICAM_SDD_VCM_USER),        value = 0xFF, flags = RESET_REQUIRED;
      endoneof;

      suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_Link5_DriverData_VcmType == 0xFF;
