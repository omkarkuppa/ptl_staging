              flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
              minimum     = 0,
              maximum     = 0x7,
              step        = 1,
            endnumeric;
          endif;
        endif;
      endif;

      // Number of GPIO pins enabled
      numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioPinsEnabled,
        prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_PIN_COUNT),
        help        = STRING_TOKEN(STR_MIPICAM_GPIO_PIN_COUNT),
        flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
        minimum     = 0,
        maximum     = 6,
        step        = 1,
      endnumeric;

      suppressif ideqval MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioPinsEnabled == 0;
      // I2C Device 0
        subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_GPIO_1);
        // GPIO Group Pad Number
        numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioGroupPadNumber[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 23,
          step        = 1,
        endnumeric;

        // GPIO Group Number
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioGroupNumber[0],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_B_F_S_V), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_C_D_E_H), value = 0x01, flags = RESET_REQUIRED;
          endoneof;

          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioComNumber[0],
