      endnumeric;

      suppressif ideqval MIPICAM_CONFIG.MipiCam_Link0_I2cDevicesEnabled == 0;
        // I2C channel
        oneof varid   = MIPICAM_CONFIG.MipiCam_Link0_I2cChannel,
          prompt      = STRING_TOKEN(STR_MIPICAM_I2C_CHANNEL),
