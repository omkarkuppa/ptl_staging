        flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
        minimum     = 6000000,
        maximum     = 27000000,
        step        = 100000,
      endnumeric;

      // EEPROM Type
      oneof varid   = MIPICAM_CONFIG.MipiCam_Link5_DriverData_EepromType,
