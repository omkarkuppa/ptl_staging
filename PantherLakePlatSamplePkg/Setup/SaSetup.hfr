          endoneof;

          // User defined GPIO Function for Control Logic 3
          suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction[4] == 0xFF;
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction_User[4],
              prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),
              help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM_HELP),
              flags       = DISPLAY_UINT_HEX,
