    // *********************************************************
    form formid = 148,
      title         = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_OPTIONS);
      subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_OPTIONS);

      // Type of logic
      oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic1_Type,
