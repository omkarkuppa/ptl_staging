    // *********************************************************
    form formid = 145,
      title         = STRING_TOKEN(STR_MIPICAM_LINK_OPTIONS);
      subtitle text = STRING_TOKEN(STR_MIPICAM_LINK4);

      oneof varid   = MIPICAM_CONFIG.MipiCam_Link4_SensorModel,
        prompt      = STRING_TOKEN(STR_MIPICAM_SENSOR_MODEL),
        help        = STRING_TOKEN(STR_MIPICAM_SENSOR_MODEL),
        option text = STRING_TOKEN(STR_MIPICAM_OV01A1S), value = 0,   flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_OV13B),   value = 1,   flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_OG0VA1B), value = 2,   flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_IMX688),  value = 3,   flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_OV08X40), value = 4,   flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_USER),    value = 255, flags = RESET_REQUIRED;
      endoneof;

      // User defined _HID for Link4
      suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_Link4_SensorModel == 255;
        string varid = MIPICAM_CONFIG.MipiCam_Link4_UserHid,
          prompt     = STRING_TOKEN(STR_MIPICAM_CUSTOM_HID),
          help       = STRING_TOKEN(STR_MIPICAM_CUSTOM_HID),
          minsize    = MIPICAM_HID_MIN_LENGTH,
          maxsize    = MIPICAM_HID_MAX_LENGTH,
        endstring;
      endif;

      // Version of CRD
      oneof varid   = MIPICAM_CONFIG.MipiCam_Link4_DriverData_CrdVersion,
        prompt      = STRING_TOKEN(STR_MIPICAM_SDD_CRD),
        help        = STRING_TOKEN(STR_MIPICAM_SDD_CRD),
        option text = STRING_TOKEN(STR_MIPICAM_SDD_CRD_D),  value = 0x20, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_SDD_CRD_G),  value = 0x30, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_SDD_CRD_G2), value = 0x50, flags = RESET_REQUIRED;
      endoneof;

      // Control Logic
      oneof varid   = MIPICAM_CONFIG.MipiCam_Link4_DriverData_ControlLogic,
