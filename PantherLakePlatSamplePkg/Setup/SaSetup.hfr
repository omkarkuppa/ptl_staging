        // GPIO Initial Value
        numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioInitialValue[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 1,
          step        = 1,
        endnumeric;

        suppressif ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioPinsEnabled == 0 1;
          // GPIO Pin 1
          subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_GPIO_1);
          // GPIO Group Pad Number
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioGroupPadNumber[1],
