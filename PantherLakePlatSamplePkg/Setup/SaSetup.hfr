          option text = STRING_TOKEN(STR_MIPICAM_I2C_DEVICE_TYPE_VCM),         value = 0x01, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_I2C_DEVICE_TYPE_EEPROM),      value = 0x02, flags = RESET_REQUIRED;
