            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER1), value = 0x01, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER3), value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER4), value = 0x03, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER5), value = 0x04, flags = RESET_REQUIRED;
          endoneof;

        // GPIO Function
        oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioFunction[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_RESET),        value = 0x00, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_POWER_EN),     value = 0x0B, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CLOCK_EN),     value = 0x0C, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_PLED_EN),      value = 0x0D, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_STROBE_EN),    value = 0x02, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_HANDSHAKE_EN), value = 0x12, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),       value = 0xFF, flags = RESET_REQUIRED;
        endoneof;

        // User defined GPIO Function for Control Logic 5
        suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioFunction[0] == 0xFF;
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic5_GpioFunction_User[0],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM_HELP),
            flags       = DISPLAY_UINT_HEX,
            minimum     = 0x15,
            maximum     = 0xFF,
            step        = 1,
