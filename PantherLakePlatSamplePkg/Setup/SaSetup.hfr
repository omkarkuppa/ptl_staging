              help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM_HELP),
              flags       = DISPLAY_UINT_HEX,
              minimum     = 0x15,
              maximum     = 0xFF,
              step        = 1,
            endnumeric;
