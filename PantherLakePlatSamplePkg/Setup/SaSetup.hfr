            option text = STRING_TOKEN(STR_XEON_LED),  value = 4, flags = RESET_REQUIRED;
          endoneof;

          suppressif ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic5_Wled2Type == 0;
            // WLED2 Flash Max current
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic5_Wled2FlashMaxCurrent,
