            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_B_F_S_V), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_C_D_E_H), value = 0x01, flags = RESET_REQUIRED;
          endoneof;

          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic2_GpioComNumber[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER0), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER1), value = 0x01, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER3), value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER4), value = 0x03, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER5), value = 0x04, flags = RESET_REQUIRED;
          endoneof;

          // GPIO Function
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic2_GpioFunction[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_RESET),        value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_POWER_EN),     value = 0x0B, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CLOCK_EN),     value = 0x0C, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_PLED_EN),      value = 0x0D, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_STROBE_EN),    value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_HANDSHAKE_EN), value = 0x12, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),       value = 0xFF, flags = RESET_REQUIRED;
          endoneof;

          // User defined GPIO Function for Control Logic 2
          suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic2_GpioFunction[5] == 0xFF;
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic2_GpioFunction_User[5],
              prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),
              help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM_HELP),
              flags       = DISPLAY_UINT_HEX,
              minimum     = 0x15,
              maximum     = 0xFF,
              step        = 1,
            endnumeric;
          endif;

          // GPIO Active Value
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic2_GpioActiveValue[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 1,
            step        = 1,
          endnumeric;

          // GPIO Initial Value
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic2_GpioInitialValue[5],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 1,
            step        = 1,
          endnumeric;
        endif;
      endif ;
    endform;

    // *********************************************************
    form formid = 150,
      title         = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_OPTIONS);
      subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_OPTIONS);

      // Type of logic
      oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_Type,
        prompt      = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_TYPE),
        help        = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_TYPE),
        option text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_DISCRETE), value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_PMIC_TPS68470),          value = 2, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_DISCRETE_HDMI2MIPI),     value = 5, flags = RESET_REQUIRED;
      endoneof;

      // Version of CRD
      oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_CrdVersion,
        prompt      = STRING_TOKEN(STR_MIPICAM_SDD_CRD),
        help        = STRING_TOKEN(STR_MIPICAM_SDD_CRD),
        option text = STRING_TOKEN(STR_MIPICAM_SDD_CRD_D),  value = 0x20, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_SDD_CRD_G2), value = 0x50, flags = RESET_REQUIRED;
      endoneof;

      // Input Clock
      oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_InputClock,
        prompt      = STRING_TOKEN(STR_MIPICAM_INPUT_CLOCK),
        help        = STRING_TOKEN(STR_MIPICAM_INPUT_CLOCK),
        option text = STRING_TOKEN(STR_MIPICAM_INPUT_CLOCK_0), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_INPUT_CLOCK_1), value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_INPUT_CLOCK_2), value = 2, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_INPUT_CLOCK_3), value = 3, flags = RESET_REQUIRED;
      endoneof;

      // Pch Clock Source
      oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_PchClockSource,
        prompt      = STRING_TOKEN(STR_MIPICAM_PCH_CLOCK_SOURCE),
        help        = STRING_TOKEN(STR_MIPICAM_PCH_CLOCK_SOURCE_HELP),
        option text = STRING_TOKEN(STR_MIPICAM_PCH_CLOCK_SOURCE_0), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_PCH_CLOCK_SOURCE_1), value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_MIPICAM_PCH_CLOCK_SOURCE_2), value = 2, flags = RESET_REQUIRED;
      endoneof;

      suppressif NOT ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic3_CrdVersion == 0x50;
        // PMIC Flash Panel
        oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_Pld,
          prompt      = STRING_TOKEN(STR_MIPICAM_PMIC_FLASH_PANEL),
          help        = STRING_TOKEN(STR_MIPICAM_PMIC_FLASH_PANEL),
          option text = STRING_TOKEN(STR_MIPICAM_LOCATION_FRONT), value = 0x21, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_LOCATION_BACK),  value = 0x29, flags = RESET_REQUIRED;
        endoneof;
      endif;

      suppressif ideqval MIPICAM_CONFIG.MipiCam_ControlLogic3_Type == 1;
        // show below options when PMIC is used
        // I2C Channel
        oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_I2cChannel,
          prompt      = STRING_TOKEN(STR_MIPICAM_I2C_CHANNEL),
          help        = STRING_TOKEN(STR_MIPICAM_I2C_CHANNEL),
          option text = STRING_TOKEN(STR_CHANNEL_I2C0), value = 0, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_CHANNEL_I2C1), value = 1, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_CHANNEL_I2C2), value = 2, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_CHANNEL_I2C3), value = 3, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_CHANNEL_I2C4), value = 4, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_CHANNEL_I2C5), value = 5, flags = RESET_REQUIRED;
        endoneof;

        // I2C address
        numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_I2cAddress,
          prompt      = STRING_TOKEN(STR_MIPICAM_I2C_ADDRESS_MAIN),
          help        = STRING_TOKEN(STR_MIPICAM_I2C_ADDRESS_MAIN),
          flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
          minimum     = 0,
          maximum     = 0x7F,
          step        = 1,
        endnumeric;

        suppressif NOT ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic3_Type == 2;
          // WLED1 Type
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled1Type,
            prompt      = STRING_TOKEN(STR_MIPICAM_WLED1_TYPE),
            help        = STRING_TOKEN(STR_MIPICAM_WLED_TYPE),
            option text = STRING_TOKEN(STR_DISABLED),  value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_WHITE_LED), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_WARM_LED),  value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_IR_LED),    value = 3, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_XEON_LED),  value = 4, flags = RESET_REQUIRED;
          endoneof;

          suppressif ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled1Type == 0;
            // WLED1 Flash Max current
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled1FlashMaxCurrent,
              prompt      = STRING_TOKEN(STR_MIPICAM_WLED1_FLASH_MAX_CURRENT),
              help        = STRING_TOKEN(STR_MIPICAM_WLED_FLASH_MAX_CURRENT),
              flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
              minimum     = 0,
              maximum     = 0x1F,
              step        = 1,
            endnumeric;

            // WLED1 Torch Max current
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled1TorchMaxCurrent,
              prompt      = STRING_TOKEN(STR_MIPICAM_WLED1_TORCH_MAX_CURRENT),
              help        = STRING_TOKEN(STR_MIPICAM_WLED_TORCH_MAX_CURRENT),
              flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
              minimum     = 0,
              maximum     = 0x7,
              step        = 1,
            endnumeric;
          endif;

          // WLED2 Type
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled2Type,
            prompt      = STRING_TOKEN(STR_MIPICAM_WLED2_TYPE),
            help        = STRING_TOKEN(STR_MIPICAM_WLED_TYPE),
            option text = STRING_TOKEN(STR_DISABLED),  value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_WHITE_LED), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_WARM_LED),  value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_IR_LED),    value = 3, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_XEON_LED),  value = 4, flags = RESET_REQUIRED;
          endoneof;

          suppressif ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled2Type == 0;
            // WLED2 Flash Max current
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled2FlashMaxCurrent,
              prompt      = STRING_TOKEN(STR_MIPICAM_WLED2_FLASH_MAX_CURRENT),
              help        = STRING_TOKEN(STR_MIPICAM_WLED_FLASH_MAX_CURRENT),
              flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
              minimum     = 0,
              maximum     = 0x1F,
              step        = 1,
            endnumeric;

            // WLED2 Torch Max current
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_Wled2TorchMaxCurrent,
              prompt      = STRING_TOKEN(STR_MIPICAM_WLED2_TORCH_MAX_CURRENT),
              help        = STRING_TOKEN(STR_MIPICAM_WLED_TORCH_MAX_CURRENT),
              flags       = RESET_REQUIRED | DISPLAY_UINT_HEX,
              minimum     = 0,
              maximum     = 0x7,
              step        = 1,
            endnumeric;
          endif;
        endif;
      endif;

      // Number of GPIO pins enabled
      numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioPinsEnabled,
        prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_PIN_COUNT),
        help        = STRING_TOKEN(STR_MIPICAM_GPIO_PIN_COUNT),
        flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
        minimum     = 0,
        maximum     = 6,
        step        = 1,
      endnumeric;

      suppressif ideqval MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioPinsEnabled == 0;
      // I2C Device 0
        subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_GPIO_1);
        // GPIO Group Pad Number
        numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioGroupPadNumber[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 23,
          step        = 1,
        endnumeric;

        // GPIO Group Number
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioGroupNumber[0],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_B_F_S_V), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_C_D_E_H), value = 0x01, flags = RESET_REQUIRED;
          endoneof;

          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioComNumber[0],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER0), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER1), value = 0x01, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER3), value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER4), value = 0x03, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER5), value = 0x04, flags = RESET_REQUIRED;
          endoneof;

        // GPIO Function
        oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_RESET),        value = 0x00, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_POWER_EN),     value = 0x0B, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CLOCK_EN),     value = 0x0C, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_PLED_EN),      value = 0x0D, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_STROBE_EN),    value = 0x02, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_HANDSHAKE_EN), value = 0x12, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),       value = 0xFF, flags = RESET_REQUIRED;
        endoneof;

        // User defined GPIO Function for Control Logic 3
        suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction[0] == 0xFF;
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction_User[0],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM_HELP),
            flags       = DISPLAY_UINT_HEX,
            minimum     = 0x15,
            maximum     = 0xFF,
            step        = 1,
          endnumeric;
        endif;

        // GPIO Active Value
        numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioActiveValue[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 1,
          step        = 1,
        endnumeric;

        // GPIO Initial Value
        numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioInitialValue[0],
          prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          help        = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
          flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
          minimum     = 0,
          maximum     = 1,
          step        = 1,
        endnumeric;

        suppressif ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioPinsEnabled == 0 1;
          // GPIO Pin 1
          subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_GPIO_2);
          // GPIO Group Pad Number
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioGroupPadNumber[1],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 23,
            step        = 1,
          endnumeric;

          // GPIO Group Number
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioGroupNumber[1],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_B_F_S_V), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_C_D_E_H), value = 0x01, flags = RESET_REQUIRED;
          endoneof;

          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioComNumber[1],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER0), value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER1), value = 0x01, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER3), value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER4), value = 0x03, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_COM_NUMBER5), value = 0x04, flags = RESET_REQUIRED;
          endoneof;

          // GPIO Function
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction[1],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION),
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_RESET),        value = 0x00, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_POWER_EN),     value = 0x0B, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CLOCK_EN),     value = 0x0C, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_PLED_EN),      value = 0x0D, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_STROBE_EN),    value = 0x02, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_HANDSHAKE_EN), value = 0x12, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),       value = 0xFF, flags = RESET_REQUIRED;
          endoneof;

          // User defined GPIO Function for Control Logic 3
          suppressif NOT ideqval MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction[1] == 0xFF;
            numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioFunction_User[1],
              prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM),
              help        = STRING_TOKEN(STR_MIPICAM_GPIO_FUNCTION_CUSTOM_HELP),
              flags       = DISPLAY_UINT_HEX,
              minimum     = 0x15,
              maximum     = 0xFF,
              step        = 1,
            endnumeric;
          endif;

          // GPIO Active Value
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioActiveValue[1],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_ACTIVE_VALUE),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 1,
            step        = 1,
          endnumeric;

          // GPIO Initial Value
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioInitialValue[1],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_INITIAL_VALUE),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 1,
            step        = 1,
          endnumeric;
        endif;

        suppressif ideqvallist MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioPinsEnabled == 0 1 2;
          // GPIO Pin 2
          subtitle text = STRING_TOKEN(STR_MIPICAM_CONTROL_LOGIC_GPIO_3);
          // GPIO Group Pad Number
          numeric varid = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioGroupPadNumber[2],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
            help        = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_PAD_NUMBER),
            flags       = RESET_REQUIRED | DISPLAY_UINT_DEC,
            minimum     = 0,
            maximum     = 23,
            step        = 1,
          endnumeric;

          // GPIO Group Number
          oneof varid   = MIPICAM_CONFIG.MipiCam_ControlLogic3_GpioGroupNumber[2],
            prompt      = STRING_TOKEN(STR_MIPICAM_GPIO_GROUP_NUMBER),
