          text   = STRING_TOKEN(STR_DIMM_MC0_CH0_SLT1_FORM_SUBTITLE),
          text   = STRING_TOKEN(STR_DIMM_MC0_CH0_SLT1_STATUS),
          flags  = 0,
          key    = 0;

