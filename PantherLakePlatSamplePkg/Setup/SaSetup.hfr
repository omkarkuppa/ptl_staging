    endform;

#if FixedPcdGetBool (PcdMipiCamFeatureEnable) == 1
    // *********************************************************
    form formid = 141,
      title         = STRING_TOKEN(STR_MIPICAM_LINK_OPTIONS);
      subtitle text = STRING_TOKEN(STR_MIPICAM_LINK0);

      oneof varid   = MIPICAM_CONFIG.MipiCam_Link0_SensorModel,
        prompt      = STRING_TOKEN(STR_MIPICAM_SENSOR_MODEL),
