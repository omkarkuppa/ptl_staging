#string STR_TURBO_MODE_ENABLE                   #language en-US "Turbo Mode"
#string STR_TURBO_MODE_ENABLE_HELP              #language en-US "Enable/Disable processor Turbo Mode."

#string STR_PLAT_PWR_LIMIT_1_ENABLE             #language en-US "Platform PL1 Enable"
#string STR_PLAT_PWR_LIMIT_1_ENABLE_HELP        #language en-US "Enable/Disable Platform Power Limit 1 programming. If this option is enabled, it activates the PL1 value to be used by the processor to limit the average power of given time window."

#string STR_PLAT_PWR_LIMIT1_PWR                 #language en-US "Platform PL1 Power"
#string STR_PLAT_PWR_LIMIT1_PWR_HELP            #language en-US "Platform Power Limit 1 Power in Milli Watts. BIOS will round to the nearest 1/8W when programming. Any value can be programmed between Max and Min Power Limits. For 12.50W, enter 12500. This setting will act as the new PL1 value for the Package RAPL algorithm."

#string STR_PLAT_PWR_LIMIT1_TIME                #language en-US "Platform PL1 Time Window"
#string STR_PLAT_PWR_LIMIT1_TIME_HELP           #language en-US "Platform Power Limit 1 Time Window value in seconds. The value may vary from 0 to 128. 0 = default values. Indicates the time window over which Platform Processor Base Power (TDP) value should be maintained."

#string STR_PLAT_PWR_LIMIT_2_ENABLE             #language en-US "Platform PL2 Enable"
#string STR_PLAT_PWR_LIMIT_2_ENABLE_HELP        #language en-US "Enable/Disable Platform Power Limit 2 programming. If this option is disabled, BIOS will program the default values for Platform Power Limit 2."

#string STR_PLAT_PWR_LIMIT2_PWR                 #language en-US "Platform PL2 Power"
#string STR_PLAT_PWR_LIMIT2_PWR_HELP            #language en-US "Platform Power Limit 2 Power in Milli Watts / Milli Percent. BIOS will round to the nearest 1/8W or 1/8% when programming. Any value can be programmed between Max and Min Power Limits (specified by PACKAGE_POWER_SKU_MSR) or PMAX value in %. For example if 12%, enter 12000, if 50%, enter 50000. If the value is '0', will default to PACKAGE_POWER_SKU_MSR if Psys is in Watts. Recommended value is 97000 if Psys is in %. This setting will act as the new PL2 value for the Package RAPL algorithm."

#string STR_PLAT_ATX_TELEMETRY_UNIT             #language en-US "ATX Telemetry Unit"
#string STR_PLAT_ATX_TELEMETRY_UNIT_HELP        #language en-US "ATX Telemetry Unit in Watts or Percentage, it indicates the telemetry type for Psys support. Psys data is in Unitless format when selecting Percentage, it is a relative % from P100%PSU rated power. Default is Watts, recommended to select Percentage when plug-in ATX12VO PSU."

#string STR_WATTS                               #language en-US "Watts"
#string STR_PERCENT                             #language en-US "Percentage"

#string STR_PKG_PWR_LIMIT_LOCK                  #language en-US "Package Power Limit MSR Lock"
#string STR_PKG_PWR_LIMIT_LOCK_HELP             #language en-US "Enable/Disable locking of Package Power Limit settings. When enabled, PACKAGE_POWER_LIMIT MSR will be locked and a reset will be required to unlock the register."

#string STR_LONG_DUR_PWR_LIMIT_OVERRIDE         #language en-US "Power Limit 1 Override"
#string STR_LONG_DUR_PWR_LIMIT_OVERRIDE_HELP    #language en-US "Enable/Disable Power Limit 1 override. If this option is disabled, BIOS will program the default values for Power Limit 1 and Power Limit 1 Time Window."

#string STR_LONG_DUR_PWR_LIMIT                  #language en-US "Power Limit 1"
#string STR_LONG_DUR_CUSTOM_PWR_LIMIT           #language en-US "Power Limit 1"
#string STR_LONG_DUR_PWR_LIMIT_HELP             #language en-US "Power Limit 1 in Milli Watts. BIOS will round to the nearest 1/8W when programming. 0 = no custom override. For 12.50W, enter 12500. Overclocking SKU: Value must be between Max and Min Power Limits. Other SKUs: This value must be between Min Power Limit and Processor Base Power (TDP) Limit. If value is 0, BIOS will program Processor Base Power (TDP) value."

#string STR_LONG_DUR_TIME_WINDOW                #language en-US "Power Limit 1 Time Window"
#string STR_LONG_DUR_CUSTOM_TIME_WINDOW         #language en-US "Power Limit 1 Time Window"
#string STR_LONG_DUR_TIME_WINDOW_HELP           #language en-US "Power Limit 1 Time Window value in seconds. The value may vary from 0 to 128. 0 = default value (28 sec for Mobile and 8 sec for Desktop). Defines time window which Processor Base Power (TDP) value should be maintained."

#string STR_SHORT_DUR_PWR_LIMIT_OVERRIDE        #language en-US "Power Limit 2 Override"
#string STR_SHORT_DUR_PWR_LIMIT_OVERRIDE_HELP   #language en-US "Enable/Disable Power Limit 2 override. If this option is disabled, BIOS will program the default values for Power Limit 2."

#string STR_SHORT_DUR_PWR_LIMIT2                #language en-US "Power Limit 2"
#string STR_SHORT_DUR_CUST_PWR_LIMIT2           #language en-US "Power Limit 2"
#string STR_SHORT_DUR_PWR_LIMIT_HELP            #language en-US "Power Limit 2 value in Milli Watts. BIOS will round to the nearest 1/8W when programming. If the value is 0, BIOS will program this value as 1.25*Processor Base Power (TDP). For 12.50W, enter 12500. Processor applies control policies such that the package power does not exceed this limit."

#string STR_PL3_FORM_TITLE                      #language en-US "Power Limit 3 Settings"
#string STR_PL3_FORM_TITLE_HELP                 #language en-US "Power Limit 3 Settings"
#string STR_POWER_LIMIT_3_OVERRIDE              #language en-US "Power Limit 3 Override "
#string STR_POWER_LIMIT_3_OVERRIDE_HELP         #language en-US "Enable/DisablePower Limit 3 override. If this option is disabled, BIOS will leave the hardware default values for Power Limit 3 and Power Limit 3 Time Window."
#string STR_POWER_LIMIT_3_LIMIT                 #language en-US "Power Limit 3"
#string STR_POWER_LIMIT_3_LIMIT_HELP            #language en-US "Platform Power Limit 3 Power in Milli Watts / Milli Percent. BIOS will round to the nearest 1/8W or 1/8% when programming. For example if 12%, enter 12000, if 50%, enter 50000.  For all SKUs, limit must be less than Psys Pmax value (either in Watts or %). XE SKU: Any value up through Psys Pmax can be programmed. Overclocking SKU: value must be between Max and Min Power Limits (specified by PACKAGE_POWER_SKU_MSR). Other SKUs: This value must be between Min Power Limit and Processor Base Power (TDP). If the value is '0', will default to hardware default value. Recommended value is 100000 if Psys is in %."
#string STR_POWER_LIMIT_3_TIME_WINDOW           #language en-US "Power Limit 3 Time Window"
#string STR_POWER_LIMIT_3_TIME_WINDOW_HELP      #language en-US "Power Limit 3 Time Window value in Milli seconds. The value may vary from 3 to 64(max). Indicates the time window over which Power Limit 3 value should be maintained. If the value is 0, BIOS leaves the hardware default value. For ATX12VO PSU systems, recommended value is 40."
#string STR_POWER_LIMIT_3_LOCK                  #language en-US "Power Limit 3 Lock"
#string STR_POWER_LIMIT_3_LOCK_HELP             #language en-US "Power Limit 3 Lock. When enabled PL3 configurations are locked during OS. When disabled PL3 configuration can be changed during OS."
#string STR_POWER_LIMIT_3_DUTY_CYCLE            #language en-US "Power Limit 3 Duty Cycle"
#string STR_POWER_LIMIT_3_DUTY_CYCLE_HELP       #language en-US "Specify the duty cycle in percentage that the CPU is required to maintain over the configured time window. Range is 0-100. For ATX12VO PSU systems, recommended value is 25."

#string STR_RESPONSE_MODE                       #language en-US "Response Mode"
#string STR_RESPONSE_MODE_HELP                  #language en-US "Response Mode is used to adjust Psys_PL3 power reduction behavior, it indicates how quickly Pcode reduces power consumption to a low (safe) level. Default is Gradual Power Reduction, recommended to select Gradual Power Reduction for Battery-enabled systems and Aggressive Power Reduction for PSU."

#string STR_GRADUAL                             #language en-US "Gradual Power Reduction"
#string STR_AGGRESSIVE                          #language en-US "Aggressive Power Reduction"

#string STR_POWER_LIMIT_4_OVERRIDE              #language en-US "Power Limit 4 Override"
#string STR_POWER_LIMIT_4_OVERRIDE_HELP         #language en-US "Enable/Disable Power Limit 4 override. If this option is disabled, BIOS will leave the default values for Power Limit 4."
#string STR_POWER_LIMIT_4_LIMIT                 #language en-US "Power Limit 4"
#string STR_POWER_LIMIT_4_LIMIT_HELP            #language en-US "Power Limit 4 in Milli Watts. BIOS will round to the nearest 1/8W when programming. For 12.50W, enter 12500. If the value is 0, BIOS leaves default value"
#string STR_POWER_LIMIT_4_LOCK                  #language en-US "Power Limit 4 Lock"
#string STR_POWER_LIMIT_4_LOCK_HELP             #language en-US "Power Limit 4 Lock. When enabled PL4 configurations are locked during OS. When disabled PL4 configuration can be changed during OS."

#string STR_CURRENT_POWER_LIMIT_4_BOOST_STRING  #language en-US "Current Power Limit 4 Boost"
#string STR_CURRENT_POWER_LIMIT_4_BOOST_VALUE   #language en-US "N/A"
#string STR_POWER_LIMIT_4_BOOST                 #language en-US "Power Limit 4 Boost"
#string STR_POWER_LIMIT_4_BOOST_HELP            #language en-US "Configure Power Limit 4 Boost in Milli Watts. BIOS will round to the nearest 1/8W when programming. For 12.50W, enter 12500. The value 0 means disable."

