#string STR_SKIN_TEMP_CONTROL_ENABLE_HELP           #language en-US "Enables Skin Temperature Control Sensors Feature"

#string STR_SKIN_TEMP_CONTROL_SENSOR_1_FORM_TITLE   #language en-US "Skin Temperature Control First Sensor"
#string STR_SKIN_TEMP_CONTROL_SENSOR_1_FORM_HELP    #language en-US "Skin Temperature Control First Sensor MMIO"

#string STR_SKIN_TEMP_CONTROL_SENSOR_2_FORM_TITLE   #language en-US "Skin Temperature Control Second Sensor"
#string STR_SKIN_TEMP_CONTROL_SENSOR_2_FORM_HELP    #language en-US "Skin Temperature Control Second Sensor MMIO"

#string STR_SKIN_TEMP_CONTROL_SENSOR_3_FORM_TITLE   #language en-US "Skin Temperature Control Third Sensor"
#string STR_SKIN_TEMP_CONTROL_SENSOR_3_FORM_HELP    #language en-US "Skin Temperature Control Third Sensor MMIO"

#string STR_TARGET_TEMP                             #language en-US "Skin Temperature Target"
#string STR_TARGET_TEMP_HELP                        #language en-US "Target temperature is limit to which the control mechanism is regulating.It is defined in 1/2 °C increments.Range is 0-127.5 °C. For a 0.5 °C temperature, enter 1. 0 = AUTO."

#string STR_SKIN_CONTROL_ENABLE_MMIO                #language en-US "Skin Control Temperature Enable MMIO"
#string STR_SKIN_CONTROL_ENABLE_MMIO_HELP           #language en-US "Enables the skin temperature control for MMIO register."

#string STR_CONTROL_LOOP_GAIN                       #language en-US "Skin Temperature Loop Gain"
#string STR_CONTROL_LOOP_GAIN_HELP                  #language en-US "Sets the aggressiveness of control loop where 0 - graceful, favors performance on expense of temperature overshoots and 7 - aggressive, favors tight regulation over performance. Range is 0-7"

#string STR_TEMP_OVERRIDE_ENABLE                    #language en-US "Skin Temperature Override Enable"
#string STR_TEMP_OVERRIDE_ENABLE_HELP               #language en-US "When set, Pcode will use TEMPERATURE_OVERRIDE values instead of reading from corresponding sensor."

#string STR_MIN_PERFORMANCE_LEVEL                   #language en-US "Skin Temperature Minimum Performance Level"
#string STR_MIN_PERFORMANCE_LEVEL_HELP              #language en-US "Minimum Performance level below which the STC limit will not throttle. 0 - all levels of throttling allowed incl. survivability actions. 256 - no throttling allowed"

#string STR_TEMP_OVERRIDE                           #language en-US "Skin Temperature Override"
#string STR_TEMP_OVERRIDE_HELP                      #language en-US "Allows SW to override the input temperature. Pcode will use this value instead of the sensor temperature. EC control is not impacted. Units: 0.5 °C. Values are 0 to 255 which represents 0-127.5 °C range"
