#string STR_ENERGY_EFFICIENT_TURBO_PROMPT       #language en-US "Energy Efficient Turbo"
#string STR_ENERGY_EFFICIENT_TURBO_HELP         #language en-US "Enable/Disable Energy Efficient Turbo Feature. This feature will opportunistically lower the turbo frequency to increase efficiency. Recommended only to disable in overclocking situations where turbo frequency must remain constant. Otherwise, leave enabled."

