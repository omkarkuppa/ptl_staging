#string STR_1_CORE_RATIO_LIMIT_HELP             #language en-US "1-Core Ratio Limit with range 0 to 83. The Minimum range may vary between Processors. This 1-Core Ratio Limit Must be greater than or equal to 2-Core Ratio Limit, 3-Core Ratio Limit, 4-Core Ratio Limit."

#string STR_2_CORE_RATIO_LIMIT                  #language en-US "2-Core Ratio Limit Override"
#string STR_2_CORE_RATIO_LIMIT_HELP             #language en-US "2-Core Ratio Limit with range 0 to 83. The Minimum range may vary between Processors. This 2-Core Ratio Limit Must be Less than or equal to 1-Core Ratio Limit."

#string STR_3_CORE_RATIO_LIMIT                  #language en-US "3-Core Ratio Limit Override"
#string STR_3_CORE_RATIO_LIMIT_HELP             #language en-US "3-Core Ratio Limit with range 0 to 83. The Minimum range may vary between Processors. This 3-Core Ratio Limit Must be Less than or equal to 1-Core Ratio Limit."

#string STR_4_CORE_RATIO_LIMIT                  #language en-US "4-Core Ratio Limit Override"
#string STR_4_CORE_RATIO_LIMIT_HELP             #language en-US "4-Core Ratio Limit with range 0 to 83. The Minimum range may vary between Processors. This 4-Core Ratio Limit Must be Less than or equal to 1-Core Ratio Limit."

#string STR_5_CORE_RATIO_LIMIT                  #language en-US "5-Core Ratio Limit Override"
#string STR_5_CORE_RATIO_LIMIT_HELP             #language en-US "5-Core Ratio Limit with range 0 to 83. The Minimum range may vary between Processors. This 5-Core Ratio Limit Must be Less than or equal to 1-Core Ratio Limit."

#string STR_6_CORE_RATIO_LIMIT                  #language en-US "6-Core Ratio Limit Override"
#string STR_6_CORE_RATIO_LIMIT_HELP             #language en-US "6-Core Ratio Limit with range 0 to 83. The Minimum range may vary between Processors. This 6-Core Ratio Limit Must be Less than or equal to 1-Core Ratio Limit."

#string STR_7_CORE_RATIO_LIMIT                  #language en-US "7-Core Ratio Limit Override"
