#string STR_TSE_PROMPT                          #language en-US "Intel(R) Total Storage Encryption"
#string STR_TSE_HELP                            #language en-US "Configure Intel(R) Total Storage Encryption"
#string STR_TME_PROMPT                          #language en-US "Total Memory Encryption"
#string STR_TME_HELP                            #language en-US "Configure Total Memory Encryption (TME) to protect DRAM data from physical attacks.\nWhen this option is configured as 'Enabled', 'VT-d' option must be 'Enabled'.\nThis option will be grayed out when 'VT-d' option is configured as 'Disabled'."
#string STR_TME_BYPASS_PROMPT                   #language en-US "Total Memory Encryption (TME) Bypass"
#string STR_TME_BYPASS_PROMPT_HELP              #language en-US "Disable/Enable Total Memory Encryption (TME)\nIf 'Enabled', then transactions with KeyID0 bypass the encryption in CCE.\n Any other KeyIDs which are configured to encrypted with KeyID0 shall also bypass the encryption in CCE if this bit is set "

#string STR_TDX_PROMPT                          #language en-US "Trust Domain Extension (TDX)"
#string STR_TDX_PROMPT_HELP                     #language en-US "Enable/Disable Trust Domain Extension (TDX). 'Total Memory Encryption' option must be 'Enabled'.\nThis option will be grayed out when 'Total Memory Encryption' option is configured as 'Disabled'."
#string STR_CPU_ATOM_CORE_FORM_TITLE            #language en-US "Efficient-core Information"
#string STR_CPU_ATOM_CORE_FORM_HELP             #language en-US "Displays the E-core Information:  L1/L2 cache includes both E-cores and LP-Ecores, L3 Cache is for P-core and E-core on ring but not shared with LP-Ecores off ring"
#string STR_CPU_CORE_FORM_TITLE                 #language en-US "Performance-core Information"
#string STR_CPU_CORE_FORM_HELP                  #language en-US "Displays the P-core Information"
#string STR_X2APIC_ENABLE_PROMPT                #language en-US "X2APIC Enable"
#string STR_X2APIC_ENABLE_HELP                  #language en-US "Enable/Disable X2APIC Operating Mode.\nWhen this option is configured as 'Enabled', 'VT-d' option must be 'Enabled'.\nThis option will be grayed out when 'VT-d' option is configured as 'Disabled'."

#string STR_POWER_FLOOR_MANAGEMENT_PROMPT           #language en-US "Power Floor Management"
#string STR_POWER_FLOOR_MANAGEMENT_HELP             #language en-US "This option is to disable SoC's aggressive throttling to manage floor power (minimum power consumption). Disabling this might effectively raise power floor of the SoC and may lead to stability issues."

#string STR_POWER_FLOOR_DISPLAY_DISCONNECT_PROMPT   #language en-US "  Display Disconnect"
#string STR_POWER_FLOOR_DISPLAY_DISCONNECT_HELP     #language en-US "When this option is enabled, SoC can disconnect secondary/external display to lower SoC floor power. When disabled, display disconnect will not be used by SoC."

#string STR_POWER_FLOOR_PCIE_GEN_DOWNGRADE_PROMPT   #language en-US "  PCIe Gen Speed Downgrade"
#string STR_POWER_FLOOR_PCIE_GEN_DOWNGRADE_HELP     #language en-US "When this option is enabled, SoC can reduce PCIe Gen speed to lower SoC floor power. When disabled, Pcie Gen speed reduction option will not be used by SoC."

