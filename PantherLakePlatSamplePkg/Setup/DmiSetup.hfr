      numeric varid = SETUP_DATA.DmiGen4RtcoCpo[OFFSET_7],
        prompt      = STRING_TOKEN(STR_DMI_RTCO_CPO_LANE7_PROMPT),
        help        = STRING_TOKEN(STR_DMI_RTCO_CPO_LANE7_HELP),
        flags       = RESET_REQUIRED,
        minimum     = 0,
        maximum     = 63,
        step        = 1,
        default     = 0,
      endnumeric;
    endform;
//end of RTCO
