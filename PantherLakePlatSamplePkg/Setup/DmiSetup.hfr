          help   = STRING_TOKEN(STR_DMI_GEN4_RTCO_EQ_RTPO_HELP);
      endif;

      SEPARATOR
      goto ADVANCED_DMI_OPTIONS_FORM_ID,
        prompt = STRING_TOKEN(STR_DMI_ADVANCED_OPTIONS),
        help   = STRING_TOKEN(STR_DMI_ADVANCED_OPTIONS);
    endform;

    form formid = ADVANCED_DMI_OPTIONS_FORM_ID,
