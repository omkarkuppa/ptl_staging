    form formid = DMI_OPTIONS_FORM_ID,
    title     = STRING_TOKEN(STR_DMI_FORM);

      oneof varid   = PCH_SETUP.DmiMaxLinkSpeed,
        prompt      = STRING_TOKEN(STR_DMI_MAX_SPEED_PROMPT),
        help        = STRING_TOKEN(STR_DMI_MAX_SPEED_HELP),
        option text = STRING_TOKEN (STR_AUTO_STRING), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN (STR_GEN1),        value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
        option text = STRING_TOKEN (STR_GEN2),        value = 2, flags = RESET_REQUIRED;
        option text = STRING_TOKEN (STR_GEN3),        value = 3, flags = RESET_REQUIRED;
        option text = STRING_TOKEN (STR_GEN4),        value = 4, flags = RESET_REQUIRED;
      endoneof;

      oneof varid = PCH_SETUP.DmiL1ssEnable,
        prompt      = STRING_TOKEN(STR_DMI_L1SS_PROMPT),
        help        = STRING_TOKEN(STR_DMI_L1SS_HELP),
        option text = STRING_TOKEN(STR_DISABLE_L1SS), value = 0,  flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLE_L1SS),  value = 1,  flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      endoneof;

      SUBTITLE(STRING_TOKEN(STR_DP_DMI_TITLE))

      oneof varid   = PCH_SETUP.DmiAspm,
        prompt      = STRING_TOKEN(STR_DMI_ASPM_PROMPT),
        help        = STRING_TOKEN(STR_DMI_ASPM_HELP),
        default = 4 , defaultstore = MyStandardDefault,
        option text = STRING_TOKEN(STR_DISABLED_STRING),        value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_AUTO_STRING),            value = 4, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_PCIE_ASPM_L0S_PROMPT),   value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_PCIE_ASPM_L1_PROMPT),    value = 2, flags = RESET_REQUIRED;
      endoneof;

      suppressif ideqval PCH_SETUP.DmiAspm == 0;
        numeric varid = PCH_SETUP.DmiAspmL1ExitLatency,
          prompt      = STRING_TOKEN(STR_DMI_L1_EXIT_LATENCY_PROMPT),
          help        = STRING_TOKEN(STR_DMI_L1_EXIT_LATENCY_HELP),
          flags       = RESET_REQUIRED,
          minimum     = 0,
          maximum     = 7,
          step        = 1,
          default     = 6,
        endnumeric;
      endif;

      oneof varid   = SETUP_DATA.Gen3RtcoRtpoEnable,
        prompt      = STRING_TOKEN(STR_DMI_GEN3_RTCO_EQ_RTPO_PROMPT),
        help        = STRING_TOKEN(STR_DMI_GEN3_RTCO_EQ_RTPO_HELP),
        option text = STRING_TOKEN(STR_DISABLED_STRING),      value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED_STRING),       value = 1, flags = RESET_REQUIRED;
      endoneof;

      goto DMI_GEN3_RTCO_COE_OVERRIDE_FORM_ID,
        prompt = STRING_TOKEN(STR_DMI_GEN3_RTCO_EQ_RTPO_PROMPT),
        help   = STRING_TOKEN(STR_DMI_GEN3_RTCO_EQ_RTPO_HELP);

      oneof varid   = SETUP_DATA.Gen4RtcoRtpoEnable,
        prompt      = STRING_TOKEN(STR_DMI_GEN4_RTCO_EQ_RTPO_PROMPT),
        help        = STRING_TOKEN(STR_DMI_GEN4_RTCO_EQ_RTPO_HELP),
        option text = STRING_TOKEN(STR_DISABLED_STRING),      value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED_STRING),       value = 1, flags = RESET_REQUIRED;
      endoneof;

      suppressif ideqval SETUP_DATA.Gen4RtcoRtpoEnable == 0;
        goto DMI_GEN4_RTCO_COE_OVERRIDE_FORM_ID,
