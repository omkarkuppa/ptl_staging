        help     = STRING_TOKEN(STR_THC_CUSTOMIZED_SVID_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0xFFFF,
        step     = 1,
        default  = 0x8086,
      endnumeric;
