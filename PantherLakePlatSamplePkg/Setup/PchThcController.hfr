#include "SetupPreProcTools.hfr"

#if defined(THC_INDEX) && (THC_INDEX < PCH_MAX_THC_CONTROLLERS)
  oneof varid  = PCH_SETUP.ThcAssignment[THC_INDEX],
    prompt   = STRING_TOKEN(STR_THC_ASSIGNMENT_TITLE),
#if (THC_INDEX == 0)
    help     = STRING_TOKEN(STR_THC_ASSIGNMENT0_HELP),
#endif
#if (THC_INDEX == 1)
    help     = STRING_TOKEN(STR_THC_ASSIGNMENT1_HELP),
#endif
    option text = STRING_TOKEN(STR_THC_ASSIGNMENT_NONE), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
#if (THC_INDEX == 0)
    option text = STRING_TOKEN(STR_THC_ASSIGNMENT_THC0), value = 1, flags = RESET_REQUIRED;
#endif
#if (THC_INDEX == 1)
    option text = STRING_TOKEN(STR_THC_ASSIGNMENT_THC1), value = 2, flags = RESET_REQUIRED;
#endif
  endoneof;

  suppressif ideqval PCH_SETUP.ThcAssignment[THC_INDEX] == 0x0;
    oneof varid  = PCH_SETUP.ThcClock[THC_INDEX],
      prompt   = STRING_TOKEN(STR_THC_CLOCK_TITLE),
      help     = STRING_TOKEN(STR_THC_CLOCK_HELP),
      option text = STRING_TOKEN(STR_THC_CLOCK_FUNC_TITLE), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_CLOCK_DFX_TITLE), value = 1, flags = RESET_REQUIRED;
    endoneof;
    numeric varid  = PCH_SETUP.ThcActiveLtr[THC_INDEX],
      prompt   = STRING_TOKEN(STR_THC_ACTIVE_LTR_TITLE),
      help     = STRING_TOKEN(STR_THC_ACTIVE_LTR_HELP),
      flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
      minimum  = 0,
      maximum  = 0xFFFFFFFF,
      step     = 1,
      default  = 0xFFFFFFFF,
    endnumeric;
    numeric varid  = PCH_SETUP.ThcIdleLtr[THC_INDEX],
      prompt   = STRING_TOKEN(STR_THC_IDLE_LTR_TITLE),
      help     = STRING_TOKEN(STR_THC_IDLE_LTR_HELP),
      flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
      minimum  = 0,
      maximum  = 0xFFFFFFFF,
      step     = 1,
      default  = 0xFFFFFFFF,
    endnumeric;
    numeric varid  = PCH_SETUP.ThcPerformanceLimitation[THC_INDEX],
      prompt   = STRING_TOKEN(STR_THC_PERFORMANCE_LIMITATION_TITLE),
      help     = STRING_TOKEN(STR_THC_PERFORMANCE_LIMITATION_HELP),
      flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
      minimum  = 0,
      maximum  = 0xFFFF,
      step     = 1,
      default  = 0,
    endnumeric;
    oneof varid  = PCH_SETUP.ThcWakeOnTouch[THC_INDEX],
      prompt   = STRING_TOKEN(STR_THC_WAKE_TITLE),
      help     = STRING_TOKEN(STR_THC_WAKE_HELP),
      option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = RESET_REQUIRED;
    endoneof;

    suppressif ideqval PCH_SETUP.ThcWakeOnTouch[THC_INDEX] == 0x0;
        oneof varid  = PCH_SETUP.ThcWotEdgeLevel[THC_INDEX],
          prompt   = STRING_TOKEN(STR_THC_WOT_EDGE_LEVEL_PROMPT),
          help     = STRING_TOKEN(STR_THC_WOT_EDGE_LEVEL_HELP),
          option text = STRING_TOKEN(STR_THC_WOT_EDGE_LEVEL_LEVEL), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
          option text = STRING_TOKEN(STR_THC_WOT_EDGE_LEVEL_EDGE), value = 1, flags = RESET_REQUIRED;
        endoneof;
        oneof varid  = PCH_SETUP.ThcWotActiveLevel[THC_INDEX],
          prompt   = STRING_TOKEN(STR_THC_WOT_ACTIVE_LEVEL_PROMPT),
          help     = STRING_TOKEN(STR_THC_WOT_ACTIVE_LEVEL_HELP),
          option text = STRING_TOKEN(STR_THC_WOT_ACTIVE_LEVEL_HIGH), value = 0, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_THC_WOT_ACTIVE_LEVEL_LOW), value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
          option text = STRING_TOKEN(STR_THC_WOT_ACTIVE_LEVEL_BOTH), value = 2, flags = RESET_REQUIRED;
        endoneof;
        oneof varid  = PCH_SETUP.ThcWotPinConfig[THC_INDEX],
          prompt   = STRING_TOKEN(STR_THC_WOT_PIN_CONFIG_PROMPT),
          help     = STRING_TOKEN(STR_THC_WOT_PIN_CONFIG_HELP),
          option text = STRING_TOKEN(STR_THC_WOT_PIN_CONFIG_PULL_DEFAULT), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
          option text = STRING_TOKEN(STR_THC_WOT_PIN_CONFIG_PULL_UP), value = 1, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_THC_WOT_PIN_CONFIG_PULL_DOWN), value = 2, flags = RESET_REQUIRED;
          option text = STRING_TOKEN(STR_THC_WOT_PIN_CONFIG_PULL_NONE), value = 3, flags = RESET_REQUIRED;
        endoneof;
      endif;

    oneof varid  = PCH_SETUP.ThcDisplayFrameSyncPeriod[THC_INDEX],
      prompt   = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_TITLE),
      help     = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_HELP),
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_10_MS), value = 10, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_20_MS), value = 20, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_30_MS), value = 30, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_40_MS), value = 40, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_50_MS), value = 50, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_60_MS), value = 60, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_70_MS), value = 70, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_80_MS), value = 80, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_90_MS), value = 90, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_DISPLAY_FRAME_SYNC_100_MS), value = 100, flags = RESET_REQUIRED;
    endoneof;
    oneof varid  = PCH_SETUP.ThcTimestampTimerMode[THC_INDEX],
