      option text = STRING_TOKEN(STR_THC_MODE_HIDSPI), value = 1, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_MODE_HIDI2C), value = 2, flags = RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_MODE_NONE),   value = 3, flags = RESET_REQUIRED;
    endoneof;

    suppressif ideqval PCH_SETUP.ThcMode[THC_INDEX] == 0x3;
