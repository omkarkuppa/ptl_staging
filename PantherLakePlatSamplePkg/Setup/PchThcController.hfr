        option text = STRING_TOKEN(STR_THC_FLAGS_SINLGE), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
        option text = STRING_TOKEN(STR_THC_FLAGS_DUAL), value = 0x4000, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_THC_FLAGS_QUAD), value = 0x8000, flags = RESET_REQUIRED;
