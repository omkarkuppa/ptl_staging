     option text = STRING_TOKEN(STR_ENABLED), value = 1, flags =  RESET_REQUIRED;
    endoneof;
    oneof varid  = PCH_SETUP.ThcResetPadTrigger[THC_INDEX],
      prompt   = STRING_TOKEN(STR_THC_RESET_PAD_TRIGGER_TITLE),
      help     = STRING_TOKEN(STR_THC_RESET_PAD_TRIGGER_HELP),
      option text = STRING_TOKEN(STR_THC_RESET_PAD_TRIGGER_LOW), value = 0, flags = DEFAULT | MANUFACTURING | RESET_REQUIRED;
      option text = STRING_TOKEN(STR_THC_RESET_PAD_TRIGGER_HIGH), value = 1, flags = RESET_REQUIRED;
    endoneof;
    oneof varid  = PCH_SETUP.ThcDsyncPad[THC_INDEX],
