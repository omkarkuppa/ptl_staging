        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0xFFFFFFFF,
        step     = 1,
        default  = 0,
      endnumeric;
      numeric varid  = PCH_SETUP.ThcHidSpiWriteOpcode[THC_INDEX],
        prompt   = STRING_TOKEN(STR_THC_WRITE_OPCODE_TITLE),
        help     = STRING_TOKEN(STR_THC_WRITE_OPCODE_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0xFFFFFFFF,
        step     = 1,
        default  = 0,
      endnumeric;
      numeric varid  = PCH_SETUP.ThcHidSpiReadOpcode[THC_INDEX],
        prompt   = STRING_TOKEN(STR_THC_READ_OPCODE_TITLE),
        help     = STRING_TOKEN(STR_THC_READ_OPCODE_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0xFFFFFFFF,
        step     = 1,
        default  = 0,
      endnumeric;
      numeric varid  = PCH_SETUP.ThcHidSpiLimitPacketSize[THC_INDEX],
        prompt   = STRING_TOKEN(STR_THC_LIMIT_PACKET_SIZE_TITLE),
        help     = STRING_TOKEN(STR_THC_LIMIT_PACKET_SIZE_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0x1,
        step     = 1,
        default  = 0,
      endnumeric;
    endif;
    suppressif NOT ideqval PCH_SETUP.ThcMode[THC_INDEX] == 0x2;
      numeric varid  = PCH_SETUP.ThcHidI2cDeviceAddress[THC_INDEX],
        prompt   = STRING_TOKEN(STR_THC_DEVICE_ADDRESS_TITLE),
        help     = STRING_TOKEN(STR_THC_DEVICE_ADDRESS_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0xFFFFFFFF,
        step     = 1,
        default  = 0,
      endnumeric;
      numeric varid  = PCH_SETUP.ThcHidI2cConnectionSpeed[THC_INDEX],
        prompt   = STRING_TOKEN(STR_THC_CONNECTION_SPEED_TITLE),
        help     = STRING_TOKEN(STR_THC_I2C_CONNECTION_SPEED_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0xFFFFFFFF,
        step     = 1,
        default  = 0,
      endnumeric;
      numeric varid  = PCH_SETUP.ThcHidI2cAddressingMode[THC_INDEX],
        prompt   = STRING_TOKEN(STR_THC_ADDRESSING_MODE_TITLE),
        help     = STRING_TOKEN(STR_THC_ADDRESSING_MODE_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 1,
        step     = 1,
