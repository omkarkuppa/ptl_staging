      endnumeric;
      numeric varid  = PCH_SETUP.ThcHidI2cMaximumLengthOfSuppressedSpikesInHighSpeedMode[THC_INDEX],
        prompt   = STRING_TOKEN(STR_THC_SUPPRESSED_SPIKES_H_TITLE),
        help     = STRING_TOKEN(STR_THC_SUPPRESSED_SPIKES_H_HELP),
        flags    = RESET_REQUIRED | DISPLAY_UINT_HEX,
        minimum  = 0,
        maximum  = 0xFFFFFFFF,
        step     = 1,
        default  = 0,
      endnumeric;
    endif;
  endif;
#endif

