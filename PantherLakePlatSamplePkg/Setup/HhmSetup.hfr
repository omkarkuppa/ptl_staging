form formid = AUTO_ID(HHM_FORM_ID),
  title     = STRING_TOKEN(STR_HHM_FORM);
  grayoutif TRUE;
    action
      questionid  = AUTO_ID(HHM_SETUP_REFRESH_KEY),
      prompt      = STRING_TOKEN(STR_HHM_FORM),
      help        = STRING_TOKEN(STR_HHM_FORM),
      flags       = INTERACTIVE,
      config      = STRING_TOKEN(STR_HHM_FORM),
      refresh interval = 1
    endaction;
  endif;
  SEPARATOR

  grayoutif TRUE;
  INTERACTIVE_TEXT(STRING_TOKEN(STR_THERMAL_SENSOR_1_HELP),STRING_TOKEN(STR_THERMAL_SENSOR_1_TEXT),STRING_TOKEN(STR_THERMAL_SENSOR_1_VALUE),AUTO_ID(THERMAL_SENSOR_1_KEY))
  INTERACTIVE_TEXT(STRING_TOKEN(STR_THERMAL_SENSOR_2_HELP),STRING_TOKEN(STR_THERMAL_SENSOR_2_TEXT),STRING_TOKEN(STR_THERMAL_SENSOR_2_VALUE),AUTO_ID(THERMAL_SENSOR_2_KEY))
  INTERACTIVE_TEXT(STRING_TOKEN(STR_THERMAL_SENSOR_3_HELP),STRING_TOKEN(STR_THERMAL_SENSOR_3_TEXT),STRING_TOKEN(STR_THERMAL_SENSOR_3_VALUE),AUTO_ID(THERMAL_SENSOR_3_KEY))
  INTERACTIVE_TEXT(STRING_TOKEN(STR_THERMAL_SENSOR_4_HELP),STRING_TOKEN(STR_THERMAL_SENSOR_4_TEXT),STRING_TOKEN(STR_THERMAL_SENSOR_4_VALUE),AUTO_ID(THERMAL_SENSOR_4_KEY))
  INTERACTIVE_TEXT(STRING_TOKEN(STR_THERMAL_SENSOR_5_HELP),STRING_TOKEN(STR_THERMAL_SENSOR_5_TEXT),STRING_TOKEN(STR_THERMAL_SENSOR_5_VALUE),AUTO_ID(THERMAL_SENSOR_5_KEY))

  INTERACTIVE_TEXT(STRING_TOKEN(STR_CPU_FAN_HELP),STRING_TOKEN(STR_CPU_FAN_TEXT),STRING_TOKEN(STR_CPU_FAN_VALUE),AUTO_ID(CPU_FAN_KEY))
  INTERACTIVE_TEXT(STRING_TOKEN(STR_PCH_DTS_TEMP_HELP),STRING_TOKEN(STR_PCH_DTS_TEMP_TEXT),STRING_TOKEN(STR_PCH_DTS_TEMP_VALUE),AUTO_ID(PCH_DTS_TEMP_KEY))
  endif;
endform;
