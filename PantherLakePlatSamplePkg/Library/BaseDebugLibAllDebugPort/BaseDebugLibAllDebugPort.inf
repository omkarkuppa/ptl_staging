[Defines]
  INF_VERSION                    = 0x00010005
  BASE_NAME                      = BaseDebugLibAllDebugPort
  MODULE_UNI_FILE                = BaseDebugLibAllDebugPort.uni
  FILE_GUID                      = 861254E8-A56C-477E-9F42-DF5974B7F9C3
  MODULE_TYPE                    = BASE
  VERSION_STRING                 = 1.0
  LIBRARY_CLASS                  = DebugLib
