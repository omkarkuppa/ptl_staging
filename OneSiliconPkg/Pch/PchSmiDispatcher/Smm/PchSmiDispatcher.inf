[Defines]
INF_VERSION = 0x00010017
BASE_NAME = PchSmiDispatcher
FILE_GUID = 438A5B8D-98D6-4CCA-A182-BA8C0471B5E8
VERSION_STRING = 1.0
MODULE_TYPE = DXE_SMM_DRIVER
PI_SPECIFICATION_VERSION = 1.10
ENTRY_POINT = InitializePchSmmDispatcher


