PmcLib
SmiHandlerProfileLib
PchPciBdfLib
PmcPrivateLibWithS3
IoTrapSocLib
P2SbSidebandAccessLib
SocInfoLib
MmRuntimeUpdateLib
PlatformPchSmiRegisterLockLib

[Packages]
MdePkg/MdePkg.dec
MdeModulePkg/MdeModulePkg.dec
OneSiliconPkg/SiPkg.dec

[Pcd]
gEfiMdeModulePkgTokenSpaceGuid.PcdProgressCodeS3SuspendStart
gEfiMdeModulePkgTokenSpaceGuid.PcdProgressCodeS3SuspendEnd
gSiPkgTokenSpaceGuid.PcdEfiGcdAllocateType


