[PcdsFixedAtBuild]
##
## PcdNemCodeCacheBase is usally the same as PEI FV Base address,
## FLASH_BASE+FLASH_REGION_FV_RECOVERY_OFFSET from PlatformPkg.fdf.
##
## Restriction:
## 1) PcdNemCodeCacheBase - (PcdTemporaryRamBase + PcdTemporaryRamSize) >= 4K
## 2) PcdTemporaryRamBase >= 4G - 64M
##
gSiPkgTokenSpaceGuid.PcdNemCodeCacheBase|0xFFF80000|UINT32|0x20000009
##
## NemCodeCacheSize is usally the same as PEI FV Size,
## FLASH_REGION_FV_RECOVERY_SIZE from PlatformPkg.fdf.
##
## Restriction:
## 1) PcdNemTotalCacheSize = NemCodeCacheSize + PcdTemporaryRamSize
## <= Maximun CPU NEM total size (Code + Data)
## = LLC size - 0.5M
## 2) PcdTemporaryRamSize  <= Maximum CPU NEM data size
## =  MLC size
## NOTE: The size restriction may be changed in next generation processor.
## Please refer to Processor BWG for detail.
##
gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress|0xFF800000|UINT32|0x10000001
gSiPkgTokenSpaceGuid.PcdBiosSize|0x00800000|UINT32|0x10000002
gSiPkgTokenSpaceGuid.PcdTopMemoryCacheSize|0x0|UINT32|0x0001002A
gSiPkgTokenSpaceGuid.PcdSecondaryDataStackBase|0xFA000000|UINT32|0x0001002B
gSiPkgTokenSpaceGuid.PcdSecondaryDataStackSize|0x00000000|UINT32|0x0001002C
gSiPkgTokenSpaceGuid.PcdEnableFspmCompression|FALSE|BOOLEAN|0x0001002D
gSiPkgTokenSpaceGuid.PcdSignedFspEnable|FALSE|BOOLEAN|0x0001002E
##
## Add Pcds to update the base address during the build.
##
gSiPkgTokenSpaceGuid.PcdFlashFvBfvBase|0xFFFFFFFC|UINT32|0x30000018
gSiPkgTokenSpaceGuid.PcdPeiCoreEntryBase|0xFFFFFFE0|UINT32|0x30000019

## PCD to indicate whether the code is in FSP binary build
gSiPkgTokenSpaceGuid.PcdFspBinaryEnable|FALSE|BOOLEAN|0x30000010
gSiPkgTokenSpaceGuid.PcdEmbeddedEnable|0x0|UINT8|0x30000012
gSiPkgTokenSpaceGuid.PcdTccSupport|0x0|UINT8|0x30000006
gSiPkgTokenSpaceGuid.PcdTsnSupport|0x0|UINT8|0x30000014
gSiPkgTokenSpaceGuid.PcdFusaSupport|0x0|UINT8|0x40000011

gSiPkgTokenSpaceGuid.PcdCanSupport|0x0|UINT8|0x30000021

gSiPkgTokenSpaceGuid.PcdPcieIpsdEnabled|FALSE|BOOLEAN|0x30000015
gSiPkgTokenSpaceGuid.PcdDmiIpsdEnabled|FALSE|BOOLEAN|0x30000017
gSiPkgTokenSpaceGuid.PcdPciMemRcrb|0x0|UINT32|0x30000020

## Bit mask of CSI EAL Context Library consistency checks.  The default is all
#  consistency checks enabled.
#  BIT0 - Enable CSI print context checks
#  BIT1 - Enable CSI error context checks
#  BIT2 - Enable CSI memory context checks
#  BIT3 - Enable CSI time context checks
#  BIT4 - Enable CSI VSC context checks
#  BIT5 - Enable CSI DFX context checks
#  BIT6 - Enable CSI register context checks
#  BIT7 - Enable CSI register access checks
# @Prompt CSI EAL Context Library consistency check mask.
gSiPkgTokenSpaceGuid.PcdCsiEalContextLibConsistencyMask|0x000000FF|UINT32|0x30000031

## Bit mask of supported CSI EAL register access types.  MMIO and Sideband
#  access types are always enabled. The default setting of this PCD leaves
#  Port I/O disabled.
#  BIT0 - Enable Port I/O register access
# @Prompt CSI EAL supported register access type mask.
gSiPkgTokenSpaceGuid.PcdCsiEalRegisterAccessTypeMask|0x00000000|UINT32|0x30000032

