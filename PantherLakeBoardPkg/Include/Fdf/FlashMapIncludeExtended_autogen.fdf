SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemorySize             = 0x00190000  #
## 1. FspTopAt4G contains FSP components (FSP-T and FSP-O) which should be put at Top 4G location, these FSP
##    components come from FSP build directly, which require base and size MUST align with the settings under
##    XXXFspPkg\XXXFspPkg.fdf - PcdFlashFvFsptSize/PcdFlashFvFspoSize
## 2. FspTopAt4G may have a padding file at start for 64KB alignment requirement or reserve size for future use.
##    So make sure PcdFspTopSize - (PcdFlashFvFspTSize + PcdFlashFvFspOSize) is at least 0x2000 (FBM_OFFSET_TO_FSPT)
SET gBoardModuleTokenSpaceGuid.PcdFspTopOffset                        = 0x02FD0000  # Flash addr (0xFFFD0000)
SET gBoardModuleTokenSpaceGuid.PcdFspTopSize                          = 0x00030000  #
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTSize                  = 0x00010000  #
SET gBoardModuleTokenSpaceGuid.PcdFlashFvFspOSize                     = 0x0001E000  #
!endif

