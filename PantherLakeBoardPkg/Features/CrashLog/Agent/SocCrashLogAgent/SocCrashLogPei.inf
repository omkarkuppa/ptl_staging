[Defines]
  INF_VERSION                    = 0x00010005
  BASE_NAME                      = SocCrashLogPei
  FILE_GUID                      = 349BABBE-7159-4E58-9462-0EEFD8EAFB86
  MODULE_TYPE                    = PEIM
  VERSION_STRING                 = 1.0
  ENTRY_POINT                    = SocCrashLogPeimEntry

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  SocCrashLogPei.c
  SocCrashLogUtils.c
  IoeCrashLogUtils.c

[Packages]
  PantherLakeBoardPkg/BoardPkg.dec
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  OneSiliconPkg/SiPkg.dec
  CrashLogFeaturePkg/CrashLogFeaturePkg.dec

[LibraryClasses]
  BaseLib
  BaseMemoryLib
  DebugLib
  MemoryAllocationLib
  PeimEntryPoint
  PeiServicesLib
  PcdLib
  PciLib
  PciSegmentLib
  TimerLib
  PmcLib
  HobLib

[Ppis]
  gEfiPeiReadOnlyVariable2PpiGuid                                 ## CONSUMES

[Guids]
  gCrashLogVariableGuid                                           ## CONSUMES
  gCrashLogCtlVariableGuid                                        ## CONSUMES
  gCrashLogRecordHobGuid                                          ## PRODUCES
  gCrashLogRecordPagesGuid                                        ## CONSUMES

[Pcd]
  gSiPkgTokenSpaceGuid.PcdSiliconInitTempMemBaseAddr              ## CONSUMES

[Depex]
  gEfiPeiMemoryDiscoveredPpiGuid