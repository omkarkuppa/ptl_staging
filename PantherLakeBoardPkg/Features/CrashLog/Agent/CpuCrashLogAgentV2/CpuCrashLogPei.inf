[Defines]
  INF_VERSION                    = 0x00010005
  BASE_NAME                      = CpuCrashLogPei
  FILE_GUID                      = 31CC66E7-F5C1-445F-A7BB-2C47743D5524
  MODULE_TYPE                    = PEIM
  VERSION_STRING                 = 1.0
