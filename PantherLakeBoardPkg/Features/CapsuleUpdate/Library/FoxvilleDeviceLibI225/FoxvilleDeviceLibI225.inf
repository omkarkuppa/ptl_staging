#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  FoxvilleInitI225.c
  I225.c
  I225.h

[Packages]
  MdePkg/MdePkg.dec

[LibraryClasses]
  DebugLib
  BaseLib
  BaseMemoryLib
  UefiLib
  MemoryAllocationLib
  UefiBootServicesTableLib

[Protocols]
  gEfiPciIoProtocolGuid                       ## CONSUMES

[Depex]
