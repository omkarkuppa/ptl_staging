[Defines]
  INF_VERSION                    = 0x00010005
  BASE_NAME                      = PlatformDataTables
#
# If the value of this GUID is changed then make sure to change the
# corresponding GUID (DPTF_ACPI_TABLE_STORAGE_GUID) in DptfAcpiTableStorage.h.
#
  FILE_GUID                      = 8A779783-8BAD-47B4-97E2-9239E3596454
  MODULE_TYPE                    = USER_DEFINED
  VERSION_STRING                 = 1.0

[Sources]
  DptfPlatformData.asl

################################################################################
#
