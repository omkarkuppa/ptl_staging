echo $1
echo $2
echo $3
echo $4

if [ "$1" = " " ]; then
  exit
fi

if [ -f $WORKSPACE_PLATFORM/$PLATFORM_PACKAGE/InternalOnly/ToolScripts/SignFv/privkey.pem ]; then
  export PRIVATE_KEY_PATH=$WORKSPACE_PLATFORM/$PLATFORM_PACKAGE/InternalOnly/ToolScripts/SignFv/privkey.pem
else
  export PRIVATE_KEY_PATH=%WORKSPACE_CORE%/BaseTools/Source/Python/Rsa2048Sha256Sign/TestSigningPrivateKey.pem
fi

Rsa2048Sha256Sign $1 $2 $3 $4 --private-key $PRIVATE_KEY_PATH

