[FV.FvUpl]
BlockSize          = $(FLASH_BLOCK_SIZE)
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE
FvNameGuid         = F69584D4-56F0-4D8E-A387-072A836CDD4E

!if gBoardModuleTokenSpaceGuid.PcdUplEnable == FALSE
  # Disable UPL build
  #   This FV is put core DXE Driver that can be shared by different bootloader
  #   after enabling UPL.elf, these driver can be take care by UPL.elf
  #
  # Process
  #   Build Phase
  #    -> Build FSP
  #    -> Build FSP Wrapper BIOS
  #   BIOS.fd -> FvUpl put Core DXE Driver that can be sharable by different
  #              bootloader
  #
  FILE FV_IMAGE = gFvUplFileGuid {
    SECTION GUIDED $(FVCOMPRESSIONGUID) PROCESSING_REQUIRED = TRUE {
      SECTION FV_IMAGE = FvUplUncompact
    }
  }
!else
  # Enable UPL build
  #   Reserved empty space, it will patch UPL.elf by FMMT in post build when enable UPL
  #
  # Process
  #   Build Phase
  #    -> Build FSP
  #    -> Build UPL
  #    -> Build FSP Wrapper BIOS
  #   Post Build Phase
  #    -> Patch UefiUPL.elf into FSP Wrapper BIOS -> FvUpl by FMMT
  #   BIOS.fd -> FvUpl put UefiUPL.elf and UefiUPL.elf contain sharable DXE drivers
  #              with different bootloader
  #
!endif

