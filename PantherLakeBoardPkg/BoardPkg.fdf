[Defines]
!if gPlatformModuleTokenSpaceGuid.PcdExtendedBiosRegionSupport == TRUE
  !include $(PLATFORM_BOARD_PACKAGE)/Include/Fdf/FlashMapIncludeExtended_autogen.fdf
!elseif gCapsuleFeaturePkgTokenSpaceGuid.PcdBiosResiliencyEnable == TRUE
    !include $(PLATFORM_BOARD_PACKAGE)/Include/Fdf/FlashMapIncludeRes.fdf
!else
  !if gMultiIbbFeaturePkgTokenSpaceGuid.PcdMultiIbbFeatureEnable == TRUE
    !include $(PLATFORM_BOARD_PACKAGE)/Include/Fdf/FlashMapIncludeMultiIbb.fdf
  !else
    !include $(PLATFORM_BOARD_PACKAGE)/Include/Fdf/FlashMapInclude.fdf
  !endif
!endif

#
# FV compression algorithm
#
!if gPlatformModuleTokenSpaceGuid.PcdLzmaEnable == TRUE
  DEFINE      FVCOMPRESSIONGUID = gLzmaCustomDecompressGuid
  DEFINE      MODULECOMPRESS    = LzmaCompress

!else
  DEFINE      FVCOMPRESSIONGUID = gTianoCustomDecompressGuid   # TianoCompress
  DEFINE      MODULECOMPRESS    = LzmaCompress
!endif
DEFINE        SIZE_4KB          = 0x1000

################################################################################
#
# FD Section
# The [FD] Section is made up of the definition statements and a
# description of what goes into  the Flash Device Image.  Each FD section
# defines one flash "device" image.  A flash device image may be one of
# the following: Removable media bootable image (like a boot floppy
# image,) an Option ROM image (that would be "flashed" into an add-in
# card,) a System "Flash"  image (that would be burned into a system's
# flash) or an Update ("Capsule") image that will be used to update and
# existing system flash.
#
################################################################################
[FD.ClientBios]
#
# FD Tokens, BaseAddress, Size, ErasePolarity, BlockSize, and NumBlocks, cannot be
# assigned with PCD values. Instead, it uses the definitions for its variety, which
# are FLASH_BASE, FLASH_SIZE, FLASH_BLOCK_SIZE and FLASH_NUM_BLOCKS.
#
BaseAddress   = $(FLASH_BASE) | gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress  #The base address of the FLASH Device.
Size          = $(FLASH_SIZE) | gSiPkgTokenSpaceGuid.PcdBiosSize             #The size in bytes of the FLASH Device
ErasePolarity = 1
BlockSize     = $(FLASH_BLOCK_SIZE)
NumBlocks     = $(FLASH_NUM_BLOCKS)

!if gBoardModuleTokenSpaceGuid.PcdSipkgBinaryEnable == TRUE
#
# It's required to put this marco in the begin of inf declare for all modules under SiPkg except SampleCode
#
DEFINE SIPKG_DXE_SMM_BIN  = INF RuleOverride = BINARY USE = X64
DEFINE SIPKG_PEI_BIN      = INF RuleOverride = BINARY USE = IA32
!else
DEFINE SIPKG_DXE_SMM_BIN  = INF
DEFINE SIPKG_PEI_BIN      = INF
!endif

# Set FLASH_REGION_FV_RECOVERY_OFFSET to PcdNemCodeCacheBase, because macro expression is not supported.
# So, PlatformSecLib uses PcdFlashAreaBaseAddress + PcdNemCodeCacheBase to get the real CodeCache base address.
SET gSiPkgTokenSpaceGuid.PcdNemCodeCacheBase = $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemoryOffset)
SET gMinPlatformPkgTokenSpaceGuid.PcdMicrocodeOffsetInFv = 0x1000
SET gIntelFsp2WrapperTokenSpaceGuid.PcdFlashCodeCacheAddress = gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress
SET gIntelFsp2WrapperTokenSpaceGuid.PcdFlashCodeCacheSize    = gSiPkgTokenSpaceGuid.PcdBiosSize
SET gIntelFsp2WrapperTokenSpaceGuid.PcdFsptBaseAddress       = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTOffset)
!if gSiPkgTokenSpaceGuid.PcdEnableFspmCompression == TRUE
#
# FSP-M to be decompressed at PcdSecondaryDataStackBase + 4K to adjust decompression
# header and align with 4K boundary.
#
SET gIntelFsp2WrapperTokenSpaceGuid.PcdFspmBaseAddress       = $(gSiPkgTokenSpaceGuid.PcdSecondaryDataStackBase) + $(SIZE_4KB)
!else
SET gIntelFsp2WrapperTokenSpaceGuid.PcdFspmBaseAddress       = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMOffset)
!endif
SET gIntelFsp2WrapperTokenSpaceGuid.PcdFspsBaseAddress       = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspSOffset)
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashAreaBaseAddress    = gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashAreaSize           = gSiPkgTokenSpaceGuid.PcdBiosSize
SET gIntelSiliconPkgTokenSpaceGuid.PcdFlashMicrocodeFvBase   = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvMicrocodeOffset)
SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvMicrocodeBase    = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvMicrocodeOffset)

!if gCapsuleFeaturePkgTokenSpaceGuid.PcdCapsuleFeatureEnable == TRUE
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashIbbBase  = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashIbbOffset)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashIbbRBase = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashIbbROffset)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashObbBase  = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashObbOffset)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashNonFitPayloadBase   = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gBoardModuleTokenSpaceGuid.PcdFlashNonFitPayloadOffset)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashNonFitPayloadOffset = $(gBoardModuleTokenSpaceGuid.PcdFlashNonFitPayloadOffset)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashNonFitPayloadSize   = $(gBoardModuleTokenSpaceGuid.PcdFlashNonFitPayloadSize)
!if gPlatformModuleTokenSpaceGuid.PcdExtendedBiosRegionSupport == TRUE
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashExtendSize = $(gBoardModuleTokenSpaceGuid.PcdFlashExtendRegionSizeInUse)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashExtendOffset = $(gBoardModuleTokenSpaceGuid.PcdFlashExtendRegionOffset)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashAllExtendedRegionSize = $(gBoardModuleTokenSpaceGuid.PcdFlashAllExtendAreaSize)
  SET gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashExtendedRegionBase = $(gBoardModuleTokenSpaceGuid.PcdFlashExtendAreaBaseAddress)
!endif
!endif

!if gFspWrapperFeaturePkgTokenSpaceGuid.PcdFspWrapperResetVectorInFsp == TRUE
  SET gFspWrapperFeaturePkgTokenSpaceGuid.PcdFspWrapperBfvforResetVectorInFsp = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemoryOffset)
  # In FSP at Reset enabled case, FSPO and FSPT should be put right below 4G location.
  SET gBoardModuleTokenSpaceGuid.PcdFlashFvFspOBase      = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gSiPkgTokenSpaceGuid.PcdBiosSize) - $(gBoardModuleTokenSpaceGuid.PcdFlashFvFspOSize)
  SET gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTBase   = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gSiPkgTokenSpaceGuid.PcdBiosSize) - $(gBoardModuleTokenSpaceGuid.PcdFlashFvFspOSize) - $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTSize)
  SET gIntelFsp2WrapperTokenSpaceGuid.PcdFsptBaseAddress = $(gSiPkgTokenSpaceGuid.PcdBiosAreaBaseAddress) + $(gSiPkgTokenSpaceGuid.PcdBiosSize) - $(gBoardModuleTokenSpaceGuid.PcdFlashFvFspOSize) - $(gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTSize)
!endif

################################################################################
#
# Following are lists of FD Region layout which correspond to the locations of different
# images within the flash device.
#
# Regions must be defined in ascending order and may not overlap.
#
# A Layout Region start with a eight digit hex offset (leading "0x" required) followed by
# the pipe "|" character, followed by the size of the region, also in hex with the leading
# "0x" characters. Like:
# Offset|Size
# PcdOffsetCName|PcdSizeCName
# RegionType <FV, DATA, or FILE>
# Fv Size can be adjusted
#
################################################################################
!if gPlatformModuleTokenSpaceGuid.PcdExtendedBiosRegionSupport == TRUE
#
#  Firmware Volumes for Extended BIOS Region
#
gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedAdvancedOffset|gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedAdvancedSize
SET gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedAdvancedBase = $(EXTENDED_REGION_MEMMAP_ADDRESS) + $(gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedAdvancedOffset)
FV = FvExtendedAdvanced

gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedPostMemoryOffset|gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedPostMemorySize
SET gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedPostMemoryBase = $(EXTENDED_REGION_MEMMAP_ADDRESS) + $(gBoardModuleTokenSpaceGuid.PcdFlashFvExtendedPostMemoryOffset)
FV = FvExtendedPostMemory

!endif

gBoardModuleTokenSpaceGuid.PcdFlashNonFitPayloadOffset|gBoardModuleTokenSpaceGuid.PcdFlashNonFitPayloadSize
gBoardModuleTokenSpaceGuid.PcdFlashNonFitPayloadBase|gBoardModuleTokenSpaceGuid.PcdFlashNonFitPayloadSize
# NotFitPayload
FV = NonFitPayloads

#
# Firmware Volumes for 16MB Region at reset vector
#
gMinPlatformPkgTokenSpaceGuid.PcdFlashNvStorageVariableOffset|gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageVariableSize
gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageVariableBase|gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageVariableSize
#NV_VARIABLE_STORE
DATA = {
  ## This is the EFI_FIRMWARE_VOLUME_HEADER
  # ZeroVector []
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  # FileSystemGuid
  0x8D, 0x2B, 0xF1, 0xFF, 0x96, 0x76, 0x8B, 0x4C,
  0xA9, 0x85, 0x27, 0x47, 0x07, 0x5B, 0x4F, 0x50,
  # FvLength: 0x60000
  0x00, 0x00, 0x06, 0x00, 0x00, 0x00, 0x00, 0x00,
  #Signature "_FVH"       #Attributes
  0x5F, 0x46, 0x56, 0x48, 0xFF, 0xFE, 0x04, 0x00,
  #HeaderLength #CheckSum #ExtHeaderOffset #Reserved #Revision
  #
  # Be careful on CheckSum field.
  #
  0x48, 0x00, 0x2E, 0x09, 0x00, 0x00, 0x00, 0x02,
  #Blockmap[0]: 6 Blocks  0x10000 Bytes / Block
  0x06, 0x00, 0x00, 0x00, 0x00, 0x00, 0x01, 0x00,
  #Blockmap[1]: End
  0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,
  ## This is the VARIABLE_STORE_HEADER
!if gMinPlatformPkgTokenSpaceGuid.PcdUefiSecureBootEnable == TRUE
  #  Signature: gEfiAuthenticatedVariableGuid = { 0xaaf32c78, 0x947b, 0x439a, { 0xa1, 0x80, 0x2e, 0x14, 0x4e, 0xc3, 0x77, 0x92 }}
  0x78, 0x2c, 0xf3, 0xaa, 0x7b, 0x94, 0x9a, 0x43,
  0xa1, 0x80, 0x2e, 0x14, 0x4e, 0xc3, 0x77, 0x92,
!else
  #  Signature: gEfiVariableGuid = { 0xddcf3616, 0x3275, 0x4164, { 0x98, 0xb6, 0xfe, 0x85, 0x70, 0x7f, 0xfe, 0x7d }}
  0x16, 0x36, 0xcf, 0xdd, 0x75, 0x32, 0x64, 0x41,
  0x98, 0xb6, 0xfe, 0x85, 0x70, 0x7f, 0xfe, 0x7d,
!endif
  #Size: 0x2E000 (gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageVariableSize) - 0x48 (size of EFI_FIRMWARE_VOLUME_HEADER) = 0x2DFB8
  # This can speed up the Variable Dispatch a bit.
  0xB8, 0xDF, 0x02, 0x00,
  #FORMATTED: 0x5A #HEALTHY: 0xFE #Reserved: UINT16 #Reserved1: UINT32
  0x5A, 0xFE, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
}
gMinPlatformPkgTokenSpaceGuid.PcdFlashNvStorageFtwWorkingOffset|gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageFtwWorkingSize
gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageFtwWorkingBase|gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageFtwWorkingSize
#NV_FTW_WORKING
DATA = {
  # EFI_FAULT_TOLERANT_WORKING_BLOCK_HEADER->Signature = gEdkiiWorkingBlockSignatureGuid         =
  #  { 0x9e58292b, 0x7c68, 0x497d, { 0xa0, 0xce, 0x65,  0x0, 0xfd, 0x9f, 0x1b, 0x95 }}
  0x2b, 0x29, 0x58, 0x9e, 0x68, 0x7c, 0x7d, 0x49,
  0xa0, 0xce, 0x65,  0x0, 0xfd, 0x9f, 0x1b, 0x95,
  # Crc:UINT32            #WorkingBlockValid:1, WorkingBlockInvalid:1, Reserved
  0xE2, 0x33, 0xF2, 0x03, 0xFE, 0xFF, 0xFF, 0xFF,
  # WriteQueueSize: UINT64
  0xE0, 0x1F, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00
}
gMinPlatformPkgTokenSpaceGuid.PcdFlashNvStorageFtwSpareOffset|gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageFtwSpareSize
gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageFtwSpareBase|gEfiMdeModulePkgTokenSpaceGuid.PcdFlashNvStorageFtwSpareSize
#NV_FTW_SPARE



!if gSiPkgTokenSpaceGuid.PcdSocCoreBootEnable == TRUE
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemoryOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemorySize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemoryBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemorySize
FV = FvPostMemory

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecurityOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecuritySize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecurityBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecuritySize
FV = FvSecurity
!endif

!if gSiPkgTokenSpaceGuid.PcdEmbeddedEnable == 0x1
gBoardModuleTokenSpaceGuid.PcdFlashFvTsnMacAddressOffset|gBoardModuleTokenSpaceGuid.PcdFlashFvTsnMacAddressSize
gBoardModuleTokenSpaceGuid.PcdFlashFvTsnMacAddressBase|gBoardModuleTokenSpaceGuid.PcdFlashFvTsnMacAddressSize
FV = FvTsnMacAddress
!endif

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvAdvancedOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvAdvancedSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvAdvancedBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvAdvancedSize
FV = FvAdvanced

!if gSiPkgTokenSpaceGuid.PcdSocCoreBootEnable == FALSE
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecurityOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecuritySize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecurityBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvSecuritySize
FV = FvSecurity
!endif

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvOsBootOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvOsBootSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvOsBootBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvOsBootSize
FV = FvOsBoot

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvUefiBootOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvUefiBootSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvUefiBootBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvUefiBootSize
FV = FvUefiBoot

gBoardModuleTokenSpaceGuid.PcdFlashFvUplOffset|gBoardModuleTokenSpaceGuid.PcdFlashFvUplSize
gBoardModuleTokenSpaceGuid.PcdFlashFvUplBase|gBoardModuleTokenSpaceGuid.PcdFlashFvUplSize
FV = FvUpl

!if gSiPkgTokenSpaceGuid.PcdSocCoreBootEnable == FALSE
gBoardModuleTokenSpaceGuid.PcdFlashFvFirmwareBinariesOffset|gBoardModuleTokenSpaceGuid.PcdFlashFvFirmwareBinariesSize
gBoardModuleTokenSpaceGuid.PcdFlashFvFirmwareBinariesBase|gBoardModuleTokenSpaceGuid.PcdFlashFvFirmwareBinariesSize
FV = FvFwBinaries
!endif

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvMicrocodeOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvMicrocodeSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvMicrocodeBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvMicrocodeSize
# FitPayload (Microcode)
FV = FvMicrocode

#
# Indicates the additional IBBs (other than IBB0 a.k.a. common IBB) used in Multi-IBB mode.
#
!if gMultiIbbFeaturePkgTokenSpaceGuid.PcdMultiIbbFeatureEnable == TRUE
  gBoardModuleTokenSpaceGuid.PcdFlashFvIbb1Offset|gBoardModuleTokenSpaceGuid.PcdFlashFvIbb1Size
  gBoardModuleTokenSpaceGuid.PcdFlashFvIbb1Base|gBoardModuleTokenSpaceGuid.PcdFlashFvIbb1Size
  FV = FvIbb1
!endif

gBoardModuleTokenSpaceGuid.PcdFlashFvIbbnp1Offset|gBoardModuleTokenSpaceGuid.PcdFlashFvIbbnp1Size
gBoardModuleTokenSpaceGuid.PcdFlashFvIbbnp1Base|gBoardModuleTokenSpaceGuid.PcdFlashFvIbbnp1Size
FV = FvIbbnp1 # FV corresponds to IBBn+1


!if gSiPkgTokenSpaceGuid.PcdSocCoreBootEnable == FALSE
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemoryOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemorySize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemoryBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPostMemorySize
FV = FvPostMemory
!endif

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspSOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspSSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspSBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspSSize
# FSP_S Section
FV = FvFspS

!if gSiPkgTokenSpaceGuid.PcdEnableFspmCompression == TRUE
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMSize
# FSP_M Section
FV = FvFspM
!else
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspMSize
# FSP_M Section
FILE = $(PLATFORM_FSP_BIN_PACKAGE)/Fsp_Rebased_M.fd
!endif

!if gFspWrapperFeaturePkgTokenSpaceGuid.PcdFspWrapperResetVectorInFsp == TRUE

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemoryOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemorySize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemoryBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemorySize
FV = FvPreMemory

gBoardModuleTokenSpaceGuid.PcdFspTopOffset|gBoardModuleTokenSpaceGuid.PcdFspTopSize
gBoardModuleTokenSpaceGuid.PcdFspTopBase|gBoardModuleTokenSpaceGuid.PcdFspTopSize
# FSP_O Section
FILE = $(PLATFORM_FSP_BIN_PACKAGE)/FspTopAt4G.fd

!else

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTSize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvFspTSize
# FSP_T Section
FILE = $(PLATFORM_FSP_BIN_PACKAGE)/Fsp_Rebased_T.fd

gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemoryOffset|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemorySize
gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemoryBase|gMinPlatformPkgTokenSpaceGuid.PcdFlashFvPreMemorySize
FV = FvPreMemory

!endif

[FV.NonFitPayloads]
BlockSize          = $(FLASH_BLOCK_SIZE)
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE
FvNameGuid         = F4E0C42C-78D2-42CD-B92A-0669FF8DE725
#
# Create an empty FV with FvNameGuid which will be patched with NonFitPayload FV in postbuild.
# FvNameGuid must match to the one in NonFitPayloadsPkg.fdf
#

[FV.FvMicrocode]
BlockSize          = $(FLASH_BLOCK_SIZE)
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE
FvNameGuid         = 62C98CCD-D8DD-4187-99AC-2B333C87B4CD
#
# Create an empty FV with FvNameGuid which will be patched with FitPayload FV in postbuild.
# FvNameGuid must match to the one in FvMicrocode.fdf
#

!if gSiPkgTokenSpaceGuid.PcdEmbeddedEnable == 0x1
!include $(COMMON_BIN_PACKAGE)/Include/Fdf/FvTsnMacAddress.fdf
!endif

!if gMultiIbbFeaturePkgTokenSpaceGuid.PcdMultiIbbFeatureEnable == TRUE
[FV.FvIbb1]
BlockSize          = $(FLASH_BLOCK_SIZE)
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE
FvNameGuid         = 6EC4B751-36C5-4BFB-A7C9-061D0AE8F69A

!include $(PLATFORM_BSP_PATH)/Include/Fdf/MultiIbb/BspPreMemoryMultiIbb1Include.fdf

#
# PCT parser should execute before PcdDisableVpdGpioTable is queried
#
INF $(PLATFORM_FULL_PACKAGE)/Features/Pct/PlatformConfigTool.inf

INF $(PLATFORM_FEATURES_PATH)/Usb4Cm/Usb4PlatformPei/Usb4PlatformPei.inf


FILE FV_IMAGE = 737FDBF8-A778-43A0-978F-7802B3E99D86 {
  SECTION FV_IMAGE = FvEndOfIbb
}

[FV.FvEndOfIbb]
BlockSize          = $(FLASH_BLOCK_SIZE)
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
READ_LOCK_CAP      = TRUE
READ_LOCK_STATUS   = TRUE
FvNameGuid         = CAAB49F4-8F4D-4ABD-9FBE-3E42701DFE86

INF MultiIbbFeaturePkg/MultiIbbService/EndOfIbbPei.inf

!endif # gMultiIbbFeaturePkgTokenSpaceGuid.PcdMultiIbbFeatureEnable

[FV.FvIbbnp1]
BlockSize          = $(FLASH_BLOCK_SIZE)
FvAlignment        = 16
ERASE_POLARITY     = 1
MEMORY_MAPPED      = TRUE
STICKY_WRITE       = TRUE
LOCK_CAP           = TRUE
LOCK_STATUS        = TRUE
WRITE_DISABLED_CAP = TRUE
WRITE_ENABLED_CAP  = TRUE
WRITE_STATUS       = TRUE
WRITE_LOCK_CAP     = TRUE
WRITE_LOCK_STATUS  = TRUE
READ_DISABLED_CAP  = TRUE
READ_ENABLED_CAP   = TRUE
READ_STATUS        = TRUE
READ_LOCK_CAP      = TRUE
