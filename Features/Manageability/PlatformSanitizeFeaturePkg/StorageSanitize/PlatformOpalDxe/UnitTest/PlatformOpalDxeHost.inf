[Defines]
  INF_VERSION    = 0x00010005
  BASE_NAME      = PlatformOpalDxeHostTest
  FILE_GUID      = df5c90f5-fa12-4aff-8680-6a6bc0e16f56
  MODULE_TYPE    = HOST_APPLICATION
  VERSION_STRING = 1.0

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  #
  # Unit Test Main
  #
  UnitTestMain.c
  #
  # Common Mock
  #
  PlatformSanitizeFeaturePkg/Test/CommonMock/UefiLibMock.c
  PlatformSanitizeFeaturePkg/Test/CommonMock/StorageSecurityProtocolMock.c
  #
  # Unit Test Case
  #
  TestCase/AddDeviceToTail/AddDeviceToTailTestCase.c
  TestCase/RemoveDevice/RemoveDeviceTestCase.c
  TestCase/OpalDriverStopDevice/OpalDriverStopDeviceTestCase.c
  TestCase/DriverBindingStop/DriverBindingStopTestCase.c
  TestCase/DriverUnload/DriverUnloadTestCase.c
  TestCase/DriverBindingSupported/DriverBindingSupportedTestCase.c
  TestCase/DriverEntryPoint/DriverEntryPointTestCase.c
  TestCase/GetOpalState/GetOpalStateTestCase.c
  TestCase/GetBlockSidState/GetBlockSidStateTestCase.c
  TestCase/OpalDriverPopUpPasswordInput/PopUpPasswordInputTestCase.c
  TestCase/OpalDiskUpdateOwnerShip/OpalDiskUpdateOwnerShipTestCase.c
  #
  # Platform IP function
  #
  PlatformSanitizeFeaturePkg/StorageSanitize/PlatformOpalDxe/PlatformOpalDxe.c
  PlatformSanitizeFeaturePkg/StorageSanitize/PlatformOpalDxe/ComponentName.c

[Packages]
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  UnitTestFrameworkPkg/UnitTestFrameworkPkg.dec
  SecurityPkg/SecurityPkg.dec
  PlatformSanitizeFeaturePkg/PlatformSanitizeFeaturePkg.dec

[LibraryClasses]
  BaseLib
  MemoryAllocationLib
  BaseMemoryLib
  DebugLib
  PrintLib
  PcdLib
  DevicePathLib
  UefiBootServicesTableLib
  TcgStorageOpalLib
  CmockaLib

[Protocols]
  gEfiStorageSecurityCommandProtocolGuid        ## CONSUMES
  gEfiBlockIoProtocolGuid                       ## CONSUMES
  gPlatformOpalProtocolGuid                     ## CONSUMES
  gEfiComponentName2ProtocolGuid                ## SOMETIMES_CONSUMES # Get Driver Name if ComponentName2Protocol exists
  gEfiComponentNameProtocolGuid                 ## SOMETIMES_CONSUMES # Get Driver Name if ComponentNameProtocol exists and ComponentName2Protocol doesn't exist
[Pcd]
  gPsFeatureModuleTokenSpaceGuid.PcdRpeOpalDriverEnable
