  MemoryAllocationLib
  UefiLib
  DebugLib
  ConfigBlockLib
  PcdLib
  DxeServicesTableLib
  TbtCommonLib
  PostCodeLib
  CmUtilsLib
  Usb4HrSrvLib
  Usb4HiCoreLib
  Usb4DomainLib
  Usb4RtEnumLib
  Usb4DebugLib
  Usb4CsLib
  CmEvtLib
