  BASE_NAME                      = Usb4CmDxe
  FILE_GUID                      = 5CD9649D-2874-4834-802B-C559C94703AE
  VERSION_STRING                 = 1.0
  MODULE_TYPE                    = DXE_DRIVER
  ENTRY_POINT                    = Usb4CmDxeEntryPoint

[LibraryClasses]
