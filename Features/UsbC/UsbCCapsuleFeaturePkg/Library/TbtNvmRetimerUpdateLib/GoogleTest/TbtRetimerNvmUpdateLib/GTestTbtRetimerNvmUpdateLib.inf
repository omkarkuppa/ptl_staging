[Defines]
  INF_VERSION     = 0x00010005
  BASE_NAME       = GoogleTestTbtRetimerNvmUpdateLib
  FILE_GUID       = F358972D-D822-47BD-B6DD-213F6F893418
  MODULE_TYPE     = HOST_APPLICATION
  VERSION_STRING  = 1.0

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  #
  # Test Main
  #
  GTestTbtRetimerNvmUpdateLib.cpp
  TestCreateHrDevInstance.cpp
  TestCreateRetimerDevInstance.cpp
  TestCreateTBTDevInstance.cpp
  TestDestroyRetimerDevInstance.cpp
  TestDestroyTbtDevInstance.cpp
  TestInitRetimerHW.cpp
  TestReadRetimerNvmVersion.cpp
  TestTbtSendOfflineMode.cpp
  TestTerminateRetimerHW.cpp
  TestUpdateDiscreteTbtNvmFirmware.cpp
  TestUpdateRetimerNvmFirmware.cpp
  TestUpdateRetimerNvmInformation.cpp
  TestTbtPdRetimerFwUpdateModeChange.cpp
  TestDriveToFwUpdateMode.cpp
  TestRestoreToOriginalMode.cpp

[Packages]
  UsbCCapsuleFeaturePkg/UsbCCapsuleFeaturePkg.dec
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  FmpDevicePkg/FmpDevicePkg.dec
  UnitTestFrameworkPkg/UnitTestFrameworkPkg.dec
  OneSiliconPkg/SiPkg.dec
  Usb4FeaturePkg/Usb4FeaturePkg.dec

[LibraryClasses]
  TbtNvmDrvRetimerThruHrLib
  TbtNvmDrvHrLib
  GoogleTestLib
  MemoryAllocationLib
  UefiBootServicesTableLib
  PcdLib
  UefiRuntimeServicesTableLib
  FirmwareManagementLib
  SubhookLib
  UsbcRetimerProtocol
  Usb4DebugLib
  MockBaseMemoryLib

[Pcd]
  gUsbCCapsuleFeaturePkgTokenSpaceGuid.PcdUsbCRetimerFlashNumber    ## CONSUMES
  gUsbCCapsuleFeaturePkgTokenSpaceGuid.PcdUsbCRetimerConfigTable    ## CONSUMES

[Guids]
