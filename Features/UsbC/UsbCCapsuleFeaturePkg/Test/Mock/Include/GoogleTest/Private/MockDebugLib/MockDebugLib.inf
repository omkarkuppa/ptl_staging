[Defines]
  INF_VERSION                    = 0x00010005
  BASE_NAME                      = MockDebugLib
  FILE_GUID                      = 45e8ecba-3eea-46d8-9cb7-0681e3c73a26
  MODULE_TYPE                    = HOST_APPLICATION
  VERSION_STRING                 = 1.0
  LIBRARY_CLASS                  = MockDebugLib

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  MockDebugLib.cpp
  DebugPrint.c

[Packages]
  MdePkg/MdePkg.dec
  OneSiliconPkg/SiPkg.dec
  UnitTestFrameworkPkg/UnitTestFrameworkPkg.dec

[LibraryClasses]
  GoogleTestLib

[BuildOptions]
  MSFT:*_*_*_CC_FLAGS = /EHsc /bigobj
