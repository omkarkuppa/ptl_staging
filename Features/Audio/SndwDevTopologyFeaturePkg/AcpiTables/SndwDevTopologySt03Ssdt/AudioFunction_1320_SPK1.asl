    0x07 ,0xDB ,0x00 ,0x10 ,0xF1,  // 0x1000DB07, 0xF1
    0x08 ,0xDB ,0x00 ,0x10 ,0x00,  // 0x1000DB08, 0x00
    0x09 ,0xDB ,0x00 ,0x10 ,0x00,  // 0x1000DB09, 0x00
