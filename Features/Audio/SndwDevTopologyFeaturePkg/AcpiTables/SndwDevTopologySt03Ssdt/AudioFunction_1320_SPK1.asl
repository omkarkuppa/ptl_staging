  Name(C031, Package()
  {
    ToUUID("daffd814-6eba-4d8c-8a91-bc9bbf4aa301"),
    Package()
    {
      // Mixer, Class, DC, The Q7.8dB format used for MU Controls represents the gain range ??28 dB to +127.996 dB
