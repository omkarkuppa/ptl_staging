    0x00, 0x77, 0x01, 0x00, // Sample Rate, 96000Hz (0x17700)
    0x10, 0x00, 0x00, 0x00, // Sample Width, 16-bits (0x10)
    0x00, 0x00, 0x00, 0x00, // Full Scale, 0 not report
