    0x00 ,0xDB ,0x00 ,0x10 ,0x02,  // 0x1000DB00, 0x02
    0x01 ,0xDB ,0x00 ,0x10 ,0x00,  // 0x1000DB01, 0x00
    0x02 ,0xDB ,0x00 ,0x10 ,0x11,  // 0x1000DB02, 0x11
