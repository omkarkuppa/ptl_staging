# Top-most EditorConfig file.
root = true

#
# Default the character set is UTF-8.
# Windows-style newlines with a newline ending every file.
#
[*]
charset = utf-8
end_of_line = crlf
indent_style = space
insert_final_newline = true

#
# Python should using the 4 space indentation.
#
[*.py]
indent_size = 4
