  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashFvTsnMacAddressOffset|0x00000000|UINT32|0x2000004B
  #####################################################################################################################
  #                                            IFWI Capsule Update Support                                            #
  #                                                  !!! Warning !!!                                                  #
  #         This PCD should be enabled in development stage, product should not enable IFWI capsule update.           #
  #####################################################################################################################
  gCapsuleFeaturePkgTokenSpaceGuid.PcdIfwiCapsuleUpdateEnable|FALSE|BOOLEAN|0xA0000112

  #
  # this PCD should be enabeld to support TopSwap SMI
  #
  gCapsuleFeaturePkgTokenSpaceGuid.PcdTopSwapSmiSupport|FALSE|BOOLEAN|0xA0000113

  #
  # Below are private PCDs.
  #
  gCapsuleFeaturePkgTokenSpaceGuid.PcdSha256DigestSupport|FALSE|BOOLEAN|0xA0000300
  gCapsuleFeaturePkgTokenSpaceGuid.PcdSha512DigestSupport|FALSE|BOOLEAN|0xA0000301

