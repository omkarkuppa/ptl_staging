  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashNonFitPayloadSize|0x00060000|UINT32|0xA0000304

[PcdsFixedAtBuild, PcdsPatchableInModule, PcdsDynamic, PcdsDynamicEx]

  # 0     : Monolithic mode  (Hide ESRT entries of standalone BIOS/ME/EC system firmware)
  # 1     : Standlone mode   (Hide ESRT entrie of monolithic system firmware)
  # Others: Both are allowed (Hide no ESRT entries)

  gCapsuleFeaturePkgTokenSpaceGuid.PcdTopSwapEnableSwSmi |0xFF|UINT8|0xA0000202
  gCapsuleFeaturePkgTokenSpaceGuid.PcdTopSwapDisableSwSmi|0xFF|UINT8|0xA0000203

  #
  # This PCD specifies the GUID for ME Capsules applied to eHAP platform
  #
  gCapsuleFeaturePkgTokenSpaceGuid.PcdObbRecoveryRequiredFvGuid|{0x0}|VOID*|0xA0000205
  gCapsuleFeaturePkgTokenSpaceGuid.PcduCodeSelectionPolicy|{0x00}|VOID*|0xFF000003
  gCapsuleFeaturePkgTokenSpaceGuid.PcdNvmeRecoveryPrimarySlotPortNumber|0|UINT32|0xA0000206
  gCapsuleFeaturePkgTokenSpaceGuid.PcdNonFitPayloadRecoveryRequiredFvGuid|{0x0}|VOID*|0xA0000208

