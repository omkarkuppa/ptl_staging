[PcdsFeatureFlag]

[PcdsFixedAtBuild]
  # Main feature PCD to support Client Capsule update feature on system firmware like BIOS, ME, EC, and etc.
  gCapsuleFeaturePkgTokenSpaceGuid.PcdCapsuleFeatureEnable|FALSE|BOOLEAN|0xA0000001

  # Sub feature PCD to support BIOS resiliency function as an add-on feature on BIOS Capsule update.
  gCapsuleFeaturePkgTokenSpaceGuid.PcdBiosResiliencyEnable|FALSE|BOOLEAN|0xA0000002

  # Sub feature PCD to support ME Code resiliency function as an add-on feature on ME Capsule update.
  gCapsuleFeaturePkgTokenSpaceGuid.PcdMeResiliencyEnable|FALSE|BOOLEAN|0xA0000003

  # Sub feature PCD to ARBH (HW Anti-Rollback) SVN check before update
  gCapsuleFeaturePkgTokenSpaceGuid.PcdCheckArbhSvnBeforeUpdate|FALSE|BOOLEAN|0xA0000004

  # NVMeRecovery PCD
  gCapsuleFeaturePkgTokenSpaceGuid.PcdNvmeRecoveryEnable|FALSE|BOOLEAN|0xA0000005

  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashObbBase|0x00000000|UINT32|0xA0000101
