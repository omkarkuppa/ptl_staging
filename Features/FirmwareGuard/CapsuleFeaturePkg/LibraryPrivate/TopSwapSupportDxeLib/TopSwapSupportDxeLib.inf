[Defines]
  INF_VERSION                    = 0x0001001B
  BASE_NAME                      = TopSwapSupportDxeLib
  FILE_GUID                      = 1026F619-0D84-4392-88BC-F50E8B871F75
  MODULE_TYPE                    = DXE_DRIVER
  VERSION_STRING                 = 1.0
  LIBRARY_CLASS                  = TopSwapSupportLib|DXE_DRIVER

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = X64
#

[Sources]
  TopSwapSupportDxeLib.c

[Packages]
  MdePkg/MdePkg.dec
  OneSiliconPkg/SiPkg.dec
  CapsuleFeaturePkg/CapsuleFeaturePkg.dec

[LibraryClasses]
  DebugLib
  IoLib
  PcdLib
  SpiAccessLib
  UefiBootServicesTableLib

[Pcd]
