[Defines]
  INF_VERSION                    = 0x00010017
  BASE_NAME                      = BiosResiliencyDxe
  FILE_GUID                      = FA8ADDEF-38F2-43A9-BF1A-2936EFC5C0CC
  VERSION_STRING                 = 1.0
  MODULE_TYPE                    = DXE_DRIVER
  UEFI_SPECIFICATION_VERSION     = 2.00
  ENTRY_POINT                    = BiosResiliencyDxeEntryPoint

[Sources]
  BiosResiliencyDxe.c
  PayloadRecovery.c

[Packages]
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  OneSiliconPkg/SiPkg.dec
  MinPlatformPkg/MinPlatformPkg.dec
  CapsuleFeaturePkg/CapsuleFeaturePkg.dec

[LibraryClasses]
  BaseLib
  BaseMemoryLib
  DebugLib
  MemoryAllocationLib
  UefiRuntimeServicesTableLib
  UefiDriverEntryPoint
  HobLib
  ComponentUpdateLib
  SeamlessRecoverySupportLib
  DxeServicesLib
  PrintLib
  CpuPlatformLib
  PlatformWdtLib
  VariablePolicyHelperLib
  CapsuleUpdateResetLib
  TopSwapSupportLib
  PlatformDxeBootStateHookLib
  HashSupportLib
  PayloadResiliencySupportLib

[Pcd]
