  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashIbbRBase               ## CONSUMES
  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashIbbROffset             ## CONSUMES
  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashIbbSize                ## CONSUMES
  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashExtendSize             ## CONSUMES
  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashExtendOffset           ## CONSUMES
  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashAllExtendedRegionSize  ## CONSUMES
  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashExtendedRegionBase     ## CONSUMES
  gCapsuleFeaturePkgTokenSpaceGuid.PcdFlashNonFitPayloadOffset    ## CONSUMES
