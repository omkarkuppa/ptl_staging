[Defines]
  INF_VERSION    = 0x00010005
  BASE_NAME      = I2cTouchPanelDxeHostTest
  FILE_GUID      = 626C3E86-B8F8-40CF-ACD8-0E59E7D40DC3
  MODULE_TYPE    = HOST_APPLICATION
  VERSION_STRING = 1.0

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  #
  # Common Mock
  #
  I2cFeaturePkg/Test/CommonMock/BootServicesMock.c
  I2cFeaturePkg/Test/CommonMock/UefiLibMock.c
  #
  # Private Mock
  #
  I2cFeaturePkg/I2cTouchPanelDxe/UnitTest/PrivateMock/PrivateMock.c
  #
  # Unit Test Main
  #
  UnitTestMain.c
  #
  # Unit Test Case
  #
  TestCase/NewRequestPacket/TestCaseNewRequestPacket.c
  TestCase/DeleteRequestPacket/TestCaseDeleteRequestPacket.c
  TestCase/TouchPanelDriverAbsolutePointerGetState/TestCaseTouchPanelDriverAbsolutePointerGetState.c
  TestCase/TouchPanelDriverUnload/TestCaseTouchPanelDriverUnload.c
  TestCase/TouchPanelDriverEntryPoint/TestCaseTouchPanelDriverEntryPoint.c
  TestCase/TouchPanelDriverDriverBindingSupported/TestCaseTouchPanelDriverDriverBindingSupported.c
  TestCase/TouchPanelDriverDriverBindingStart/TestCaseTouchPanelDriverDriverBindingStart.c
  TestCase/TouchPanelDriverDriverBindingStop/TestCaseTouchPanelDriverDriverBindingStop.c
  TestCase/TouchPanelDriverAbsolutePointerReset/TestCaseTouchPanelDriverAbsolutePointerReset.c
  TestCase/GetLength/TestCaseGetLength.c
  TestCase/HidDescriptorReceivedEvent/TestCaseHidDescriptorReceivedEvent.c
  TestCase/GetHidDescriptor/TestCaseGetHidDescriptor.c
  TestCase/SetHidPower/TestCaseSetHidPower.c
  TestCase/SetHidReset/TestCaseSetHidReset.c
  TestCase/GetTouchCoordinates/TestCaseGetTouchCoordinates.c
  TestCase/CheckDataAvailableCallback/TestCaseCheckDataAvailableCallback.c
  TestCase/TouchDevInit/TestCaseTouchDevInit.c
  TestCase/GetToken/TestCaseGetToken.c
  TestCase/ExportReport/TestCaseExportReport.c
  TestCase/UpdateStack/TestCaseUpdateStack.c
  TestCase/AccessBit/TestCaseAccessBit.c
  TestCase/ShowReportTable/TestCaseShowReportTable.c
  TestCase/SetInterruptFrequency/TestCaseSetInterruptFrequency.c
  TestCase/ReadInputReportDescriptor/TestCaseReadInputReportDescriptor.c
  TestCase/ParseInput/TestCaseParseInput.c
  TestCase/TouchPanelDriverComponentNameGetDriverName/TestCaseTouchPanelDriverComponentNameGetDriverName.c
  TestCase/TPLDriverComponentNameGetControllerName/TestCaseTouchPanelDriverComponentNameGetControllerName.c
  #
  # Platform IP function
  #
  I2cFeaturePkg/I2cTouchPanelDxe/I2cTouchPanel.c
  I2cFeaturePkg/I2cTouchPanelDxe/ComponentName.c

[Packages]
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  UnitTestFrameworkPkg/UnitTestFrameworkPkg.dec
  I2cFeaturePkg/I2cFeaturePkg.dec
  VirtualKeyboardFeaturePkg/VirtualKeyboardFeaturePkg.dec

[LibraryClasses]
  BaseLib
  DebugLib
  UnitTestLib
  BaseMemoryLib
  MemoryAllocationLib
  PrintLib
  CmockaLib
  UefiBootServicesTableLib

[Protocols]
  gEfiAbsolutePointerProtocolGuid               ## PRODUCES
  gEfiDriverBindingProtocolGuid                 ## SOMETIMES_PRODUCES
  gEfiDriverSupportedEfiVersionProtocolGuid     ## PRODUCES
  gEfiI2cIoProtocolGuid                         ## CONSUMES
  gEfiComponentName2ProtocolGuid                ## PRODUCES
  gEfiComponentNameProtocolGuid                 ## PRODUCES

[Guids]
  gEdkiiTouchPanelGuid                          ## PRODUCES
  gI2cTouchPanelDeviceGuid                      ## CONSUMES
