[Defines]
  INF_VERSION    = 0x00010005
  BASE_NAME      = I2cMonzaDxeHostTest
  FILE_GUID      = 539BE8EC-546E-40A6-90E8-A6959B9B1796
  MODULE_TYPE    = HOST_APPLICATION
  VERSION_STRING = 1.0

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  #
  # Common Mock
  #
  I2cFeaturePkg/Test/CommonMock/BootServicesMock.c
  I2cFeaturePkg/Test/CommonMock/UefiLibMock.c
  #
  # Private Mock
  #
  I2cFeaturePkg/I2cPssMonzaDxe/UnitTest/PrivateMock/PrivateMock.c
  #
  # Unit Test Main
  #
  UnitTestMain.c
  #
  # Unit Test Case
  #
  TestCase/PssMonzaDriverEntryPoint/TestCasePssMonzaDriverEntryPoint.c
  TestCase/PssMonzaDriverBindingSupported/TestCasePssMonzaDriverBindingSupported.c
  TestCase/PssMonzaDriverBindingStart/TestCasePssMonzaDriverBindingStart.c
  TestCase/PssMonzaDriverBindingStop/TestCasePssMonzaDriverBindingStop.c
  TestCase/PssMonzaDriverComponentNameGetDriverName/TestCasePssMonzaDriverComponentNameGetDriverName.c
  TestCase/PssMonzaDriverComponentNameGetControllerName/TestCasePssMonzaDriverComponentNameGetControllerName.c
  TestCase/PssMonzaNewRequestPacket/TestCasePssMonzaNewRequestPacket.c
  TestCase/PssMonzaDeleteRequestPacket/TestCasePssMonzaDeleteRequestPacket.c
  TestCase/PssMonzaReadData/TestCasePssMonzaReadData.c
  TestCase/IsPssMonzaExist/TestCaseIsPssMonzaExist.c
  TestCase/PssMonzaGetSerialNumber/TestCasePssMonzaGetSerialNumber.c
  TestCase/PssMonzaGetMacAddress/TestCasePssMonzaGetMacAddress.c
  #
  # Platform IP function
  #
  I2cFeaturePkg/I2cPssMonzaDxe/I2cPssMonzaDxe.c
  I2cFeaturePkg/I2cPssMonzaDxe/I2cPssMonzaDevice.c
  I2cFeaturePkg/I2cPssMonzaDxe/ComponentName.c

[Packages]
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  UnitTestFrameworkPkg/UnitTestFrameworkPkg.dec
  I2cFeaturePkg/I2cFeaturePkg.dec

[LibraryClasses]
  BaseLib
  DebugLib
  UnitTestLib
  BaseMemoryLib
  MemoryAllocationLib
  PrintLib
  CmockaLib
  UefiBootServicesTableLib


[Protocols]
  gEfiDriverBindingProtocolGuid                          ## PRODUCES
  gEfiI2cIoProtocolGuid                                  ## CONSUMES
  gI2cPssProtocolGuid                                    ## PRODUCES

[Guids]
  gI2cPssMonzaDeviceGuid                                 ## CONSUMES
