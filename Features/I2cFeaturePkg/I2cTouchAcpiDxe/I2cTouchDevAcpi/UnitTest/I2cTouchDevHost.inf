[Defines]
  INF_VERSION    = 0x00010005
  BASE_NAME      = I2cTouchDevHostTest
  FILE_GUID      = 9c86bf9c-c664-41ea-8b15-b750b16cfee2
  MODULE_TYPE    = HOST_APPLICATION
  VERSION_STRING = 1.0

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES = IA32 X64
#

[Sources]
  #
  # Unit Test Main
  #
  UnitTestMain.c
  #
  # Common Mock
  #
  I2cFeaturePkg/Test/CommonMock/BootServicesMock.c
  #
  # Private Mock
  #
  PrivateMock/PrivateMock.c
  #
  # PreRequisite
  #
  PreRequisite/I2cDevPatchEntry/PreI2cDevPatchEntry.c
  PreRequisite/I2CBoardData/PreI2CBoardData.c
  PreRequisite/PatchRtd3Buffer/PrePatchRtd3Buffer.c
  PreRequisite/PatchI2cDevicesBuffer/PrePatchI2cDevicesBuffer.c
  #
  # Unit Test Case
  #
  TestCase/I2cDevPatchEntry/TestCaseI2cDevPatchEntry.c
  TestCase/I2CBoardData/TestCaseI2CBoardData.c
  TestCase/PatchRtd3Buffer/TestCasePatchRtd3Buffer.c
  TestCase/PatchI2cDevicesBuffer/TestCasePatchI2cDevicesBuffer.c
  #
  # Clean Up
  #
  CleanUp/I2cDevPatchEntry/CleanUpI2cDevPatchEntry.c
  CleanUp/I2CBoardData/CleanUpI2CBoardData.c
  CleanUp/PatchRtd3Buffer/CleanUpPatchRtd3Buffer.c
  CleanUp/PatchI2cDevicesBuffer/CleanUpPatchI2cDevicesBuffer.c
  #
  # Platform IP function
  #
  I2cFeaturePkg/I2cTouchAcpiDxe/I2cTouchDevAcpi/I2cTouchDev.c

[Packages]
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  UnitTestFrameworkPkg/UnitTestFrameworkPkg.dec
  I2cFeaturePkg/I2cFeaturePkg.dec

[LibraryClasses]
  BaseLib
  DebugLib
  UnitTestLib
  BaseMemoryLib
  MemoryAllocationLib
  PrintLib
  UefiLib
  CmockaLib

[Protocols]
  gI2cDeviceInfoProtocolGuid
  gI2cDeviceProtocolGuid

[Pcd]
  gI2cFeaturePkgTokenSpaceGuid.PcdI2cDevTableName  ## CONSUMES
