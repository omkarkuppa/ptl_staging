  BaseLib
  BaseMemoryLib
  MemoryAllocationLib
  PeiServicesLib
  IoLib
  PeimEntryPoint
  DebugLib
  PcdLib

[Packages]
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  BoardModulePkg/BoardModulePkg.dec
  XmlCliFeaturePkg/XmlCliFeaturePkg.dec

