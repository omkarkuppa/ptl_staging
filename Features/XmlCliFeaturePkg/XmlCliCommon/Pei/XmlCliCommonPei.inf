[Defines]
  INF_VERSION                    = 0x00010017
  BASE_NAME                      = XmlCliCommonPei
  FILE_GUID                      = 47727552-A54B-4A84-8CC1-BFF23E249637
  VERSION_STRING                 = 1.0
  MODULE_TYPE                    = PEIM
  ENTRY_POINT                    = PeimXmlCliEntryPoint

#
# The following information is for reference only and not required by the build tools.
#
# VALID_ARCHITECTURES = IA32 X64 IPF EBC
#

