[LibraryClasses]
  BaseLib
  DebugLib
  UnitTestLib
  MemoryAllocationLib
  PrintLib
  PcdLib
  DevicePathLib
  CmockaLib

[Protocols]
  gNvmeEraseBlockProtocolGuid                   ## PRODUCES
  gEfiDevicePathProtocolGuid                    ## CONSUMES
  gEfiNvmExpressPassThruProtocolGuid            ## CONSUMES
  gEfiBlockIoProtocolGuid                       ## CONSUMES

