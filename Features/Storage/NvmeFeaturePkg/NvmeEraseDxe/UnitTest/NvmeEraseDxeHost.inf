  # PreRequisite
  #
  PreRequisite/PreRequisite.c
  #
  # Clean Up
  #
  CleanUp/CleanUp.c
  #
  # Unit Test Case
  #
  TestCase/GetParentProtocol/TestCase.c
  TestCase/GetParentProtocol/PreRequisite.c
  TestCase/GetParentProtocol/CleanUp.c
  TestCase/IsNvmeDevice/TestCase.c
  TestCase/IsNvmeDevice/PreRequisite.c
  TestCase/IsNvmeDevice/CleanUp.c
  TestCase/NvmeEraseBindingSupported/TestCase.c
  TestCase/NvmeEraseBindingSupported/PreRequisite.c
  TestCase/NvmeEraseBindingSupported/CleanUp.c
  TestCase/NvmeEraseEntryPoint/TestCase.c
  TestCase/NvmeEraseEntryPoint/PreRequisite.c
  TestCase/NvmeEraseEntryPoint/CleanUp.c
  TestCase/NvmeIdentifyController/TestCase.c
  TestCase/NvmeIdentifyController/PreRequisite.c
  TestCase/NvmeIdentifyController/CleanUp.c
  TestCase/NvmeFormatNvmCommand/TestCase.c
  TestCase/NvmeFormatNvmCommand/PreRequisite.c
  TestCase/NvmeFormatNvmCommand/CleanUp.c
  TestCase/NvmeDataOverwrite/TestCase.c
  TestCase/NvmeDataBlockErase/TestCase.c
  TestCase/NvmeDataBlockErase/PreRequisite.c
  TestCase/NvmeDataBlockErase/CleanUp.c
  TestCase/NvmeDataCryptoErase/TestCase.c
  TestCase/NvmeDataCryptoErase/PreRequisite.c
  TestCase/NvmeDataCryptoErase/CleanUp.c
