[Defines]
  INF_VERSION                    = 0x0001001D
  BASE_NAME                      = MultiIbbServiceHostTest_Ibbnp1
  FILE_GUID                      = 48AFB75A-71AB-4EC6-B344-A3DF225F0801
  MODULE_TYPE                    = HOST_APPLICATION
  VERSION_STRING                 = 1.0

#
# The following information is for reference only and not required by the build tools.
#
#  VALID_ARCHITECTURES           = IA32 X64
#

[Sources]
  #
  # Unit Test Main
  #
  UnitTestMain.c
  #
  # Private Mock
  #
  PrivateMock/PrivateMock.c
  #
  # PreRequisite
  #
  PreRequisite/MultiIbbServiceEntryPoint/PreMultiIbbServiceEntryPoint.c
  PreRequisite/CreateSha384Hash/PreCreateSha384Hash.c
  PreRequisite/FvIntegrityCheck/PreFvIntegrityCheck.c
  PreRequisite/MemoryDiscoveredPpiNotifyCallback/PreMemoryDiscoveredPpiNotifyCallback.c

  #
  # Unit Test Case
  #
  TestCase/MultiIbbServiceEntryPoint/TestCaseMultiIbbServiceEntryPoint.c
  TestCase/CreateSha384Hash/TestCaseCreateSha384Hash.c
  TestCase/FvIntegrityCheck/TestCaseFvIntegrityCheck.c
  TestCase/MemoryDiscoveredPpiNotifyCallback/TestCaseMemoryDiscoveredPpiNotifyCallback.c
  #
  # Clean Up
  #
  CleanUp/MultiIbbServiceEntryPoint/CleanUpMultiIbbServiceEntryPoint.c
  CleanUp/CreateSha384Hash/CleanUpCreateSha384Hash.c
  CleanUp/FvIntegrityCheck/CleanUpFvIntegrityCheck.c
  CleanUp/MemoryDiscoveredPpiNotifyCallback/CleanUpMemoryDiscoveredPpiNotifyCallback.c
  #
  # Platform IP function
  #
  MultiIbbFeaturePkg/MultiIbbService/MultiIbbServicePei.c

[Packages]
  MdePkg/MdePkg.dec
  MdeModulePkg/MdeModulePkg.dec
  UnitTestFrameworkPkg/UnitTestFrameworkPkg.dec
  MultiIbbFeaturePkg/MultiIbbFeaturePkg.dec
  MinPlatformPkg/MinPlatformPkg.dec
  OneSiliconPkg/SiPkg.dec
  CryptoPkg/CryptoPkg.dec
  UefiCpuPkg/UefiCpuPkg.dec

[LibraryClasses]
  BaseLib
  DebugLib
  UnitTestLib
  BaseMemoryLib
  MemoryAllocationLib
  PrintLib
  PcdLib
  UefiLib
  CmockaLib
  PeiServicesLib
  BaseCryptLib
  CacheMaintenanceLib
  AccessNemConfigLib
  MtrrLib

[Ppis]
  gPeiFirmwareVolumeVerifyHashFvPpiGuid     ## CONSUMES
  gEfiPeiMemoryDiscoveredPpiGuid            ## Notify

[Pcd]
